@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MFA Verification - Transmittal Module</title>
    <link href="~/css/mfa.css" rel="stylesheet" />
    <style type="text/css">
    
