                        <td>
                            <span class="badge bg-danger">
                                Absent
                            </span>
                        </td>

                        <td>

                            <button class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </button>

                            <button class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>

