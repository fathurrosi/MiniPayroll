                        <th>Employee</th>

                        <th>Department</th>

                        <th>Date</th>

                        <th>Shift</th>

                        <th>Time In</th>

                        <th>Time Out</th>

                        <th>Late</th>

                        <th>Status</th>

                        <th width="120">Action</th>

                    </tr>

                </thead>

                <tbody>

