@using App.Domain.Models
@using App.Domain.Models.Dto.Masters
@model PageModel<BranchDto>
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
}

<link rel="stylesheet" href="~/plugins/select2/css/select2.min.css">
<link rel="stylesheet" href="~/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css">

<style>
    /* Mengatasi select2 yang sering overflow atau terlalu mepet di bootstrap 4 theme */
    .select2-container--bootstrap4 .select2-selection--single {
        height: calc(2.25rem + 2px) !important;
    }
    .select2-container--bootstrap4 .select2-selection--single .select2-selection__rendered {
        line-height: 2.25rem !important;
        padding-left: 0.75rem !important;
    }
    .select2-container--bootstrap4 .select2-selection--single .select2-selection__arrow {
        height: 2.25rem !important;
    }
    /* Memperbaiki jarak dropdown parent di dalam modal */
    .select2-dropdown {
        border: 1px solid #ced4da !important;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
</style>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">
                <div class="d-flex align-items-center">
                    <h6 class="mb-0 fw-semibold">
                        Existing @Model.Title
                    </h6>
                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new" class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i> Add New
                        </button>
                        <button id="csv-export" class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i> Export CSV
                        </button>
                        <button id="pdf-export" class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i> Export PDF
                        </button>
                    </div>
                </div>
            </div>

            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table" class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="BranchModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header bg-light py-3">
                <h5 class="modal-title fs-6 fw-bold text-secondary">
                    <i class="fa-solid fa-building text-primary me-2"></i>
                    <span id="modalTitle">Add @Model.Title</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">
                <form id="BranchForm" asp-action="Save" method="post" enctype="multipart/form-data" autocomplete="off">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Mode)
                    @Html.HiddenFor(model => model.Title)        
                    
                    <div class="row">        
                        <div class="col-md-12 mb-3">
                            <label asp-for="Item.BranchCode" class="form-label fw-semibold"></label>
                            <input asp-for="Item.BranchCode" id="Item_BranchCode" asp-key="true" class="form-control" placeholder="e.g. BR01, BR-JKT" maxlength="20" />
                            <span asp-validation-for="Item.BranchCode" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label asp-for="Item.BranchName" class="form-label fw-semibold"></label>
                            <input asp-for="Item.BranchName" id="Item_BranchName" class="form-control" placeholder="e.g. Jakarta Main Branch" />
                            <span asp-validation-for="Item.BranchName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label asp-for="Item.Address" class="form-label fw-semibold"></label>
                            <textarea asp-for="Item.Address" id="Item_Address" class="form-control" rows="2" placeholder="e.g. Jl. Sudirman No. 12"></textarea>
                            <span asp-validation-for="Item.Address" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label asp-for="Item.BranchHeadEmployeeId" class="form-label fw-semibold">Branch Head</label>
                            <div class="w-100">
                                <select asp-for="Item.BranchHeadEmployeeId" id="Item_BranchHeadEmployeeId" class="form-control select2" style="width: 100%;" data-placeholder="Search Branch Head..."></select>
                            </div>
                            <span asp-validation-for="Item.BranchHeadEmployeeId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label asp-for="Item.CompanyProfileId" class="form-label fw-semibold">Company</label>
                            <div class="w-100">
                                <select asp-for="Item.CompanyProfileId" id="Item_CompanyProfileId" class="form-control select2" style="width: 100%;" data-placeholder="Search Company..."></select>
                            </div>
                            <span asp-validation-for="Item.CompanyProfileId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mt-2">
                            <div class="form-check form-switch d-flex align-items-center gap-3 ps-0">
                                <input asp-for="Item.IsActive" id="Item_IsActive" class="form-check-input ms-0" type="checkbox" role="switch" style="cursor: pointer;" />
                                <label asp-for="Item.IsActive" class="form-check-label fw-semibold" style="cursor: pointer;"></label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light py-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetForm()">
                    <i class="fa-solid fa-rotate-left me-1"></i> Reset
                </button>
                <button id="save-button" type="button" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script src="~/plugins/select2/js/select2.full.min.js"></script>

    <script>
        function closeModal() {
            const modalElement = document.getElementById('BranchModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            if (modal) {
                modal.hide();
            }
        }

        function showModal(code) {
            $('#modalTitle').text(code ? 'Edit Branch' : 'Add Branch');
            if (!code) {
                resetForm();
                $('input[name="Mode"]').val('1'); // FormMode.Create
                $('#Item_BranchCode').prop('readonly', false);
            } else {
                $('input[name="Mode"]').val('2'); // FormMode.Update
                $('#Item_BranchCode').prop('readonly', true);
            }
            const modal = new bootstrap.Modal(document.getElementById('BranchModal'));
            modal.show();
        }

        $(document).ready(function () {

            $('#Item_BranchHeadEmployeeId').select2({
                theme: 'bootstrap4',
                dropdownParent: $('#BranchModal'),
                allowClear: true,
                placeholder: 'Search Branch Head...',
                ajax: {
                    url: '@Url.Action("GetEmployeeDropdown", "Branch")',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return { searchTerm: params.term };
                    },
                    processResults: function (data) {
                        return { results: data };
                    },
                    cache: true
                }
            });

            $('#Item_CompanyProfileId').select2({
                theme: 'bootstrap4',
                dropdownParent: $('#BranchModal'),
                allowClear: true,
                placeholder: 'Search Company...',
                ajax: {
                    url: '@Url.Action("GetCompanyDropdown", "Branch")',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return { searchTerm: params.term };
                    },
                    processResults: function (data) {
                        return { results: data };
                    },
                    cache: true
                }
            });

            // Validasi input manual BranchCode
            $('#Item_BranchCode').on('keydown', function (e) {
                if (e.key === " ") {
                    e.preventDefault();
                }
            });

            $('#Item_BranchCode').on('input', function () {
                this.value = this.value.toUpperCase().replace(/\s+/g, '');
            });

            // Inisialisasi Server-Side DataTables untuk Branch
            const table = $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,
                ajax: {
                    url: '@Url.Action("GetList", "Branch")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403) return;
                        notify.error('Failed to load Branch data');
                    }
                },
                columnDefs: [
                    {
                        targets: -1,
                        className: 'not-export'
                    }
                ],
                columns: [
                    { data: 'branchCode', title: 'Branch Code', defaultContent: '-' },
                    { data: 'branchName', title: 'Branch Name', defaultContent: '-' },
                    {
                        data: 'isActive',
                        title: 'Is Active',
                        className: 'text-center',
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row) {
                            const checked = data ? 'checked' : '';
                            return `
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input status-switch" type="checkbox" role="switch" ${checked}
                                    onclick="confirmStatusChange('${row.branchCode}', this)">
                                </div>
                            `;
                        }
                    },
                    {
                        data: null,
                        title: 'Action',
                        orderable: false,
                        searchable: false,
                        className: 'text-center action-col',
                        width: '100px',
                        render: function (data, type, row) {
                            return `
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <a href="javascript:void(0)" onclick="editRow('${row.branchCode}')" title="Edit">
                                        <i class="fa-solid fa-pen-to-square text-primary"></i>
                                    </a>
                                    <a href="javascript:void(0)" onclick="confirmDelete(() => deleteRow('${row.branchCode}'))" title="Delete">
                                        <i class="fa-solid fa-trash text-danger"></i>
                                    </a>
                                </div>
                            `;
                        }
                    }
                ],
                dom: "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>rt<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    { extend: 'csvHtml5', className: 'btn-export-csv d-none', title: '@Model.Title', exportOptions: { columns: ':not(.not-export)' } },
                    { extend: 'pdfHtml5', className: 'btn-export-pdf d-none', title: '@Model.Title', exportOptions: { columns: ':not(.not-export)' } }
                ]
            });

            $('#csv-export').on('click', function () { $('.btn-export-csv').trigger('click'); });
            $('#pdf-export').on('click', function () { $('.btn-export-pdf').trigger('click'); });
            $('#add-new').on('click', function () { showModal(); });
            $('#save-button').on('click', function () { saveBranch(); });
        });

        function confirmStatusChange(branchCode, element) {
            const isChecked = $(element).is(':checked');
            const statusText = isChecked ? 'ACTIVATE' : 'DEACTIVATE';
            const alertClass = isChecked ? 'text-success' : 'text-danger';

            Swal.fire({
                title: 'Are you sure?',
                html: `You are about to <b class="${alertClass}">${statusText}</b> Branch Code: <b>${branchCode}</b>.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: isChecked ? '#28a745' : '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, change it!',
                cancelButtonText: 'Cancel',
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    executeStatusUpdate(branchCode, isChecked, element);
                } else {
                    $(element).prop('checked', !isChecked);
                }
            });
        }

        function executeStatusUpdate(branchCode, isChecked, element) {
            $.ajax({
                type: 'POST',
                url: '/Branch/UpdateStatus',
                data: {
                    code: branchCode,
                    isActive: isChecked
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message || 'Status updated successfully.');
                    } else {
                        notify.warning(response.message || 'Failed to update status.');
                        $(element).prop('checked', !isChecked);
                    }
                },
                error: function () {
                    notify.error('An error occurred while communicating with the server.');
                    $(element).prop('checked', !isChecked);
                }
            });
        }

        function saveBranch() {
            const form = $('#BranchForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("SaveAsync", "Branch")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403) return;
                    notify.error('An error occurred while saving Branch');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }

function editRow(code) {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetData", "Branch")',
                data: { code: code },
                success: function (data) {
                    if (!data) {
                        notify.warning('Branch not found');
                        return;
                    }             
                    // 1. Mengisi input teks biasa
                    $('#Item_BranchCode').val(data.branchCode);                    
                    $('#Item_BranchName').val(data.branchName);                      
                    $('#Item_Address').val(data.address);                      
                    $('#Item_IsActive').prop('checked', data.isActive);                      

                    // ====================================================================
                    // TAMBAHKAN DI SINI: Proses set nilai ID untuk Dropdown Select2 AJAX
                    // ====================================================================
                    
                    // Untuk Dropdown Branch Head (Menggunakan Employee Code sebagai ID)
                    if (data.branchHeadEmployee) { // Sesuaikan nama properti JSON dari backend Anda
                        // Format Option: new Option("Teks yang Tampil", "Nilai ID yang disimpan", true, true)
                        var empText = `[${data.branchHeadEmployee}] ${data.branchHeadEmployeeName || ''}`;
                        var empOption = new Option(empText, data.branchHeadEmployee, true, true);
                        
                        $('#Item_BranchHeadEmployee').append(empOption).trigger('change');
                    } else {
                        $('#Item_BranchHeadEmployee').val(null).trigger('change');
                    }

                    // Untuk Dropdown Company (Menggunakan CompanyProfileId sebagai ID angka)
                    if (data.company) { // Jika dari backend nama propertinya data.company / data.companyProfileId
                        var compOption = new Option(data.companyName || 'Selected Company', data.company, true, true);
                        
                        $('#Item_Company').append(compOption).trigger('change');
                    } else {
                        $('#Item_Company').val(null).trigger('change');
                    }
                    
                    // ====================================================================

                    // 2. Tampilkan modal setelah semua data terisi
                    showModal(data.branchCode);
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403) return;
                    notify.error('Failed to retrieve Branch data');
                }
            });
        }

        function deleteRow(code) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("Delete", "Branch")',
                data: { code: code },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403) return;
                    notify.error('Failed to delete Branch');
                }
            });
        }

        function resetForm() {
            $('#BranchForm')[0].reset();
            $('#Item_BranchHeadEmployee').val(null).trigger('change');
            $('#Item_Company').val(null).trigger('change');
        }
    </script>
}