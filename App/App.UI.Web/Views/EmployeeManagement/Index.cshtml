<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container-fluid mt-3">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    Employee Management
                </div>

                <div class="list-group list-group-flush">

                    <a href="#" class="list-group-item list-group-item-action active">
                        <i class="bi bi-people"></i>
                        Employee List
                    </a>

                    <a href="#" class="list-group-item list-group-item-action">
                        <i class="bi bi-person-plus"></i>
                        Add Employee
                    </a>

                </div>
            </div>
        </div>

        <!-- Content -->
        <div class="col-md-9 col-lg-10">

            <div class="card shadow">

                <div class="card-header d-flex justify-content-between">

                    <div>
                        <h4 class="mb-0">John Doe</h4>
                        <small class="text-muted">
                            EMP0001 | Software Engineer
                        </small>
                    </div>

                    <button class="btn btn-primary">
                        Edit Employee
                    </button>

                </div>

                <div class="card-body">

                    <!-- Tabs -->
                    <ul class="nav nav-tabs" id="employeeTab" role="tablist">

                        <li class="nav-item">
                            <button class="nav-link active"
                                    data-bs-toggle="tab"
                                    data-bs-target="#general">
                                General
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#employment">
                                Employment
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#family">
                                Family
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#education">
                                Education
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#experience">
                                Experience
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#certificate">
                                Certificates
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#document">
                                Documents
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#contact">
                                Emergency
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#bank">
                                Bank
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#tax">
                                Tax
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#bpjs">
                                BPJS
                            </button>
                        </li>

                    </ul>

                    <!-- Tab Contents -->

                    <div class="tab-content mt-4">

                        <div class="tab-pane fade show active" id="general">
                            <h5>Employee Profile</h5>
                            <hr>

                            <div class="row">

                                <div class="col-md-3 text-center">

                                    <img src="https://via.placeholder.com/180"
                                         class="img-thumbnail rounded-circle">

                                    <br><br>

                                    <button class="btn btn-outline-primary btn-sm">
                                        Change Photo
                                    </button>

                                </div>

                                <div class="col-md-9">

                                    <table class="table table-borderless">

                                        <tr>
                                            <th width="180">Employee ID</th>
                                            <td>EMP0001</td>
                                        </tr>

                                        <tr>
                                            <th>Full Name</th>
                                            <td>John Doe</td>
                                        </tr>

                                        <tr>
                                            <th>Email</th>
                                            <td>john@company.com</td>
                                        </tr>

                                        <tr>
                                            <th>Phone</th>
                                            <td>08123456789</td>
                                        </tr>

                                    </table>

                                </div>

                            </div>

                        </div>

                        <div class="tab-pane fade" id="employment">
                            <h5>Employment History</h5>
                            <p>Promotion, Transfer, Contract, Position History...</p>
                        </div>

                        <div class="tab-pane fade" id="family">
                            <h5>Family Information</h5>
                        </div>

                        <div class="tab-pane fade" id="education">
                            <h5>Education</h5>
                        </div>

                        <div class="tab-pane fade" id="experience">
                            <h5>Working Experience</h5>
                        </div>

                        <div class="tab-pane fade" id="certificate">
                            <h5>Certificates</h5>
                        </div>

                        <div class="tab-pane fade" id="document">
                            <h5>Employee Documents</h5>
                        </div>

                        <div class="tab-pane fade" id="contact">
                            <h5>Emergency Contact</h5>
                        </div>

                        <div class="tab-pane fade" id="bank">
                            <h5>Bank Account</h5>
                        </div>

                        <div class="tab-pane fade" id="tax">
                            <h5>Tax Information</h5>
                        </div>

                        <div class="tab-pane fade" id="bpjs">
                            <h5>BPJS Information</h5>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>