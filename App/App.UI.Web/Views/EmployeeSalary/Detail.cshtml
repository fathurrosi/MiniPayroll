@model EmployeeSalaryCreateModel
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
    var orderedComponents = Model.Components
      .OrderBy(c => c.SortOrder)
      .ToList();
}

<div class="card">
    <div class="card-header">
        Employee Selection
    </div>

    <div class="card-body">

        <div class="row">
            <div class="col-md-3">
                Employee
                <select asp-for="EmployeeId"
                        class="form-select">
                         
                    @foreach (var employee in Model.Employees)
                    {
                        <option value="@employee.EmployeeId">
                            @employee.FullName
                        </option>
                    }
                     
                </select>
            </div>
            <div class="col-md-3">
                Department
                <select asp-for="DepartmentCode"
                        class="form-select">

                    <option value="">
                        -- Select Department --
                    </option>

                    @foreach (var department in Model.Departments)
                    {
                        <option value="@department.DepartmentCode">
                            @department.DepartmentName
                        </option>
                    }

                </select>
            </div>

            <div class="col-md-3">
                Position
                <select asp-for="PositionCode"
                        class="form-select">

                    <option value="">
                        -- Select Position --
                    </option>

                    @foreach (var position in Model.Positions)
                    {
                        <option value="@position.PositionCode">
                            @position.PositionName
                        </option>
                    }

                </select>
            </div>

            <div class="col-md-2">
                <button type="button"
                        id="btnSearchEmployee"
                        class="btn btn-primary mt-4">
                    Search
                </button>
            </div>
        </div>

        <hr />

        <table id="tblEmployee"
               class="table table-bordered">
            <thead>
                <tr>
                    <th width="50">
                        <input type="checkbox"
                               id="chkAll" />
                    </th>
                    <th>Employee No</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Position</th>
                </tr>
            </thead>

            <tbody>
            </tbody>
        </table>

    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        Salary Components
    </div>

    <div class="card-body">

        @foreach (var item in orderedComponents)
        {
            <div class="row mb-2">
                <div class="col-md-3">
                    @item.ComponentName
                </div>

                <div class="col-md-9">
                    <input type="number"
                           name="item.Amount"
                           class="form-control text-end" />

                    <input type="hidden"
                           name="item.ComponentCode"
                           value="@item.ComponentCode" />
                </div>
            </div>
        }

    </div>
</div>

<div class="mt-3 text-end">
    <button class="btn btn-success">
        Save
    </button>

    <a asp-action="Index"
           class="btn btn-secondary">
        Cancel
    </a>
</div>