@model EmployeeSalaryCreateModel
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
    var orderedComponents = Model.Components
      .OrderBy(c => c.SortOrder)
      .ToList();
}

<div class="card">
    <div class="card-header">
        Employee Selection
    </div>

    <div class="card-body">

        <div class="row">
            
            <div class="col-md-3">
                Department
                <select asp-for="DepartmentCode"
                        class="form-select">

                    <option value="">
                        -- Select Department --
                    </option>

                    @foreach (var department in Model.Departments)
                    {
                        <option value="@department.DepartmentCode">
                            @department.DepartmentName
                        </option>
                    }

                </select>
            </div>

            <div class="col-md-3">
                Position
                <select asp-for="PositionCode"
                        class="form-select">

                    <option value="">
                        -- Select Position --
                    </option>

                    @foreach (var position in Model.Positions)
                    {
                        <option value="@position.PositionCode">
                            @position.PositionName
                        </option>
                    }

                </select>
            </div>
            <div class="col-md-3">
                Employee
                <select asp-for="EmployeeId"
                        class="form-select">
                         
                    <option value="">
                        -- Select Employee --
                    </option>

                    @foreach (var employee in Model.Employees)
                    {
                        <option value="@employee.EmployeeId">
                            @employee.FullName
                        </option>
                    }
                     
                </select>
            </div>

            <div class="col-md-2">
                <button type="button"
                        id="btnSearchEmployee"
                        class="btn btn-primary mt-4">
                    Search
                </button>
            </div>
        </div>

        <hr />

        <table id="tblEmployee"
               class="table table-bordered">
            <thead>
                <tr>
                    <th width="50">
                        <input type="checkbox"
                               id="chkAll" />
                    </th>
                    <th>Employee No</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Position</th>
                    <th>Effective Date</th>
                    <th>Is Active</th>
                </tr>
            </thead>

            <tbody>
            </tbody>
        </table>

    </div>
</div>

<div class="card mt-3">
    <div class="card-header">
        Salary Components
    </div>

    <div class="card-body">
        @foreach (var item in orderedComponents)
        {
            <div class="row mb-2">
                <div class="col-md-3">
                    @item.ComponentName
                </div>
                <div class="col-md-4">
                    <input type="number"
                           class="form-control text-end salary-component"
                           data-component-code="@item.ComponentCode"
                           value="0" />
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-3 text-end">
    <button type="button"
            id="btnSave"
            class="btn btn-success">
        Save
    </button>

    <a asp-action="Index"
           class="btn btn-secondary">
        Cancel
    </a>
</div>


@section Scripts {

    <script>
        function getSelectedEmployees() {

            var employeeIds = [];
            $('.employee-checkbox:checked').each(function () {
                employeeIds.push($(this).val());
            });

            return employeeIds;
        }
        $(document).on('change', '#chkAll', function () {
            $('.employee-checkbox').prop(
                'checked',
                $(this).prop('checked')
            );
        });


        $(document).ready(function () {

             
            $("#btnSave").click(function () {
                var employees = [];
                $(".employee-checkbox:checked").each(function () {                    
                    const row = $(this).closest("tr");
                    employees.push({
                        employeeId: parseInt($(this).val()),
                        effectiveDate: row.find(".effective-date").val(),
                        isActive: row.find(".is-active").prop("checked")
                    });

                });

                if (employees.length === 0) {
                    notify.warning("Please select employee.");
                    return;
                }

                var components = [];

                $(".salary-component").each(function () {

                    components.push({
                        componentCode: $(this).data("component-code"),
                        defaultAmount: parseFloat($(this).val()) || 0
                    });

                });

                var request = {
                    employeeSalaries: employees,
                    components: components
                }; 
                $.ajax({
                    url: '@Url.Action("Add", "EmployeeSalary")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(request),
                    success: function (response) {
                        if (response.success) {
                            notify.success(response.message);
                            window.location.href = '@Url.Action("Index", "EmployeeSalary")';
                        }
                        else {
                            notify.warning(response.message);
                        }
                    },

                    error: function () {
                        notify.error("Failed to save employee salary.");
                    }
                });

            });

            $("#btnSearchEmployee").click(function () {
                var departmentCode = $("#DepartmentCode").val();
                var positionCode = $("#PositionCode").val();
                var employeeId = $("#EmployeeId").val(); 
                $.ajax({
                    url: '@Url.Action("GetList", "Employee")',
                    type: 'GET',
                    data: {
                        departmentCode: departmentCode,
                        positionCode: positionCode,
                        employeeId: employeeId
                    },
                    success: function (response) {
                        var tbody = $("#tblEmployee tbody");
                        tbody.empty();
                        $.each(response, function (i, employee) {
                            var row =
                                `<tr>
                                    <td>
                                        <input type="checkbox"
                                               class="employee-checkbox"
                                               value="${employee.employeeId}" />
                                    </td>
                                    <td>${employee.employeeCode}</td>
                                    <td>${employee.fullName}</td>
                                    <td>${employee.department}</td>
                                    <td>${employee.position}</td>
                                    <td>
                                        <input type="date" class="form-control form-control-sm effective-date" />
                                    </td>

                                    <td class="text-center">
                                        <input type="checkbox" class="is-active" checked />
                                    </td>

                                </tr>`;
                            tbody.append(row);
                        });
                    },
                    error: function () {
                        notify.error("Failed to load employees.");
                    }
                });
            });

        });

    </script>

}