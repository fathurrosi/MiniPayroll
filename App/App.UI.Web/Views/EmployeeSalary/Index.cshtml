<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">
            Employee Salary
        </h5>
    </div>

    <div class="card-body">

        <form id="EmployeeSalaryForm">

            <!-- Header -->
            <div class="row g-3 mb-4">

                <div class="col-md-6">
                    <label class="form-label fw-semibold">
                        Employee
                    </label>

                    <select asp-for="Item.EmployeeId"
                            class="form-select">
                        <option value="">
                            -- Select Employee --
                        </option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        Effective Date
                    </label>

                    <input asp-for="Item.EffectiveDate"
                           type="date"
                           class="form-control" />
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">
                        Status
                    </label>

                    <select asp-for="Item.IsActive"
                            class="form-select">
                        <option value="true">
                            Active
                        </option>
                        <option value="false">
                            Inactive
                        </option>
                    </select>
                </div>

            </div>

            <hr />

            <!-- Detail -->
            <div class="d-flex justify-content-between align-items-center mb-3">

                <h6 class="mb-0">
                    Salary Components
                </h6>

                <button type="button"
                        id="btnAddComponent"
                        class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-plus"></i>
                    Add Component
                </button>

            </div>

            <div class="table-responsive">
                <table id="detailTable"
                       class="table table-sm table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:50%">
                                Component
                            </th>
                            <th style="width:30%"
                                class="text-end">
                                Amount
                            </th>
                            <th style="width:20%"
                                class="text-center">
                                Action
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>

            <div class="text-end mt-3">
                <button type="button"
                        id="btnSave"
                        class="btn btn-success">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save
                </button>
            </div>
        </form>
    </div>
</div>

                        
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let detailIndex = 0;
        function addComponentRow() {
            let row = `
                <tr>
                    <td>
                        <select name="Details[${detailIndex}].ComponentCode"
                                class="form-select component-select">
                            <option value="">
                                -- Select Component --
                            </option>
                           
                        </select>
                    </td>
                    <td>
                        <input type="number"
                               step="0.01"
                               name="Details[${detailIndex}].Amount"
                               class="form-control text-end"
                               value="0" />
                    </td>
                    <td class="text-center">
                        <button type="button"
                                class="btn btn-sm btn-danger btn-remove">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `;

            $('#detailTable tbody').append(row);
            detailIndex++;
        }

        $(document).ready(function () {
            $('#btnAddComponent').on('click', function () {
                addComponentRow();
            });
            $(document).on('click', '.btn-remove', function () {
                $(this).closest('tr').remove();
            });
        });
       
    </script>
}