@model EmployeeSalaryModel

@{
    var orderedComponents = Model.Components
        .OrderBy(c => c.SortOrder)
        .ToList();
}

<style>
    .salary-input {
        min-width: 120px;
        text-align: right;
    }

    #tblSalary th,
    #tblSalary td {
        vertical-align: middle;
        white-space: nowrap;
    }
</style>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm">

            <div class="card-header py-2 px-3 bg-light">

                <div class="d-flex align-items-center">

                    <h6 class="mb-0 fw-semibold">
                        Employee Salary
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                  
                        <button class="btn btn-success"
                                data-bs-toggle="modal"
                                data-bs-target="#generateScheduleModal">
                            <i class="bi bi-plus"></i>
                            Add Employee Salary
                        </button>
                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>
                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>

                    </div>
                </div>
            </div>

            <div class="card-body">

                <div class="row mb-3">

                  @*   <div class="col-md-3">
                        <select asp-for="Year" class="form-select">
                            @for (int i = DateTime.Now.Year - 2;
                                   i <= DateTime.Now.Year + 2;
                                   i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <select asp-for="Month" class="form-select">

                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i">
                                    @(new DateTime(2000, i, 1)
                                        .ToString("MMMM"))
                                </option>
                            }

                        </select>
                    </div> *@
                    <div class="col-md-3">
                        <select asp-for="EmployeeId"
                                class="form-select">

                            <option value="">
                                -- Select Employee --
                            </option>

                            @foreach (var employee in Model.Employees)
                            {
                                <option value="@employee.EmployeeId">
                                    @employee.FullName
                                </option>
                            }

                        </select>
                    </div>

                    <div class="col-md-4">
                        <select asp-for="DepartmentCode"
                                class="form-select">

                            <option value="">
                                -- Select Department --
                            </option>

                            @foreach (var department in Model.Departments)
                            {
                                <option value="@department.DepartmentCode">
                                    @department.DepartmentName
                                </option>
                            }

                        </select>
                    </div>

                    <div class="col-md-4">
                        <select asp-for="PositionCode"
                                class="form-select">

                            <option value="">
                                -- Select Position --
                            </option>

                            @foreach (var position in Model.Positions)
                            {
                                <option value="@position.PositionCode">
                                    @position.PositionName
                                </option>
                            }

                        </select>
                    </div>

                    <div class="col-md-1">
                        <button id="btnSearch"
                                class="btn btn-primary w-100">
                            Search
                        </button>
                    </div>

                </div>

                <div class="table-responsive">
                    <table id="tblSalary"
                           class="table table-sm table-bordered table-hover w-100">
                    </table>
                </div>

                <div class="mt-3 text-end">
                    <button id="btnSave"
                            class="btn btn-success">
                        Save
                    </button>
                </div>

            </div>

        </div>
    </div>
</div>
>
@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script>

        let table;

        function buildColumns() {

            let columns = [
                {
                    data: 'employeeCode',
                    title: 'Employee No'
                },
                {
                    data: 'employeeName',
                    title: 'Employee Name'
                }
            ];

            @foreach (var c in orderedComponents)
            {
                <text> columns.push({
                          data: 'components.@c.ComponentCode',
                          title: '@c.ComponentName',
                          className: 'text-end',
                          orderable: false,
                          render: function (data, type, row) {
                              data = data ?? 0;
                              return ` <input type="number" class="form-control form-control-sm salary-input"
                              data-component="@c.ComponentCode" value="${data}" /> `;
                          }
                     });
                </text>
            }

            return columns;
        }

        function loadSalary() {

            if ($.fn.DataTable.isDataTable('#tblSalary')) {
                table.destroy();
                $('#tblSalary').empty();
            }

            table = $('#tblSalary').DataTable({

                processing: true,
                serverSide: true,
                searching: false,
                ordering: false,

                scrollX: true,
                scrollCollapse: true,
                autoWidth: false,

                fixedColumns: {
                    left: 2
                },

                ajax: {
                    url: '@Url.Action("GetList", "EmployeeSalary")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {

                        // d.year = $('#Year').val();
                        // d.month = $('#Month').val();
                        d.employeeId = $('#EmployeeId').val();
                        d.departmentCode = $('#DepartmentCode').val();
                        d.positionCode = $('#PositionCode').val();
                        return JSON.stringify(d);
                    }
                },

                columns: buildColumns(),
                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    {
                        extend: 'csvHtml5',
                        className: 'btn-export-csv d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn-export-pdf d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    }
                ]
            });
        }

        $(document).ready(function () {

            loadSalary();

            $('#btnSearch').click(function () {
                loadSalary();
            });

        });

        $('#csv-export').on('click', function () {
            $('.btn-export-csv').trigger('click');
        });

        $('#pdf-export').on('click', function () {
            $('.btn-export-pdf').trigger('click');
        });

        $('#tblSalary').on(
            'change',
            '.salary-input',
            function () {

                let input = $(this);
                let tr = input.closest('tr');
                let row = table.row(tr).data();

                let componentCode =
                    input.data('component');

                let amount =
                    parseFloat(input.val()) || 0;

                row.components[componentCode] =
                    amount;
            });

        $('#btnSave').click(function () {

            let salaries = [];

            table.rows().every(function () {

                let row = this.data();

                let details = [];

                for (const componentCode
                        in row.components) {

                    details.push({
                        componentCode: componentCode,
                        amount:
                            parseFloat(
                                row.components[componentCode]
                            ) || 0
                    });
                }

                salaries.push({
                    employeeSalaryId:
                        row.employeeSalaryId,
                    employeeId:
                        row.employeeId,
                    year:
                        $('#Year').val(),
                    month:
                        $('#Month').val(),
                    details: details
                });
            });

            $.ajax({
                url:
                    '@Url.Action("Save", "EmployeeSalary")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(salaries),
                success: function (response) {

                    if (response.success) {
                        toastr.success('Saved');
                    }
                    else {
                        toastr.error(response.message);
                    }
                },
                error: function () {
                    toastr.error('Server error.');
                }
            });

        });

    </script>
}