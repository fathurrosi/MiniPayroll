@using App.Domain.Models
@using App.Domain.Models.Dto
@model PageModel<HolidayDto>
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
}

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">

                <div class="d-flex align-items-center">

                    <h6 class="mb-0 fw-semibold">
                        Existing @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>

                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>

                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>

                    </div>

                </div>

            </div>
            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
     
</div>
 
<div class="modal fade"
     id="holidayModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa-solid fa-building me-2"></i>
                    <span id="modalTitle">
                        Add @Model.Title
                    </span>
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="holidayForm"
                      asp-action="Save"
                      method="post"
                      enctype="multipart/form-data"
                      autocomplete="off">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Mode)
                    @Html.HiddenFor(model => model.Title)
                    <input type="hidden"
                           asp-for="Item.Id"
                           asp-key="true" />
           
                    <div class="row g-3">
                    
                        <div class="col-md-12">
                            <label asp-for="Item.HolidayDate"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.HolidayDate"
                                   type="date"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   class="form-control" />
                            <span asp-validation-for="Item.HolidayDate"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Item.HolidayName"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.HolidayName"
                                   class="form-control"
                                   placeholder="e.g. Idul Fitri" />
                            <span asp-validation-for="Item.HolidayName"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <div class="form-check mt-2">
                                <input asp-for="Item.IsNationalHoliday"
                                       type="checkbox"
                                       class="form-check-input"
                                       id="chkNationalHoliday" />
                                <label asp-for="Item.IsNationalHoliday"
                                       class="form-check-label fw-semibold"
                                       for="chkNationalHoliday"
                                       style="cursor: pointer;"></label>
                            </div>
                            <span asp-validation-for="Item.IsNationalHoliday"
                                  class="text-danger small"></span>
                        </div>

                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        onclick="resetForm()">
                    <i class="fa-solid fa-rotate-left me-1"></i>
                    Reset
                </button>
                <button id="save-button"
                        type="button"
                        class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('holidayModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            setReadonly(false);
            if (modal) {
                modal.hide();
            }
        }
        function showModal(id) {
            $('#modalTitle').text(
                id > 0 ? 'Edit Holiday' : 'Add Holiday'
            );

            setReadonly(id > 0 ? true : false);
            const modal = new bootstrap.Modal(
                document.getElementById('holidayModal')
            );
            modal.show();
        }
        $(document).ready(function () {
             $('#logoFile').on('change', function () {
                 const file = this.files[0];
                 const preview = document.getElementById('logoPreview');
                 if (!file) {
                     preview.style.display = 'none';
                     return;
                 }
                 preview.src = URL.createObjectURL(file);
                 preview.style.display = 'block';
            });

            const table =  $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,
                order: [[0, 'desc']],
                ajax: {
                    url: '@Url.Action("GetList", "Holiday")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;
                        notify.error('Failed to load Holiday data');
                    }
                },
                columnDefs: [
                    {
                        targets: -1,
                        className: 'not-export'
                    }
                ],
                 columns: [
                      {
                         data: 'holidayDate',
                         title: 'Holiday Date',
                         render: function (data) {
                             if (!data) return '-';
            
                             // 1. Extract just the date part (ignores time if present)
                             var datePart = data.split('T')[0];
                             var parts = datePart.split('-');
            
                             // 2. Ensure we have YYYY, MM, and DD parts
                             if (parts.length === 3) {
                                 var year = parts[0];
                                 var monthIndex = parseInt(parts[1], 10) - 1;
                                 var day = parts[2].padStart(2, '0');
                
                                 // 3. Define short month names
                                 var months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                
                                 return day + ' ' + months[monthIndex] + ' ' + year;
                             }
            
                             return data; // Fallback if data format is unexpected
                         }
                     },
                     { data: 'holidayName', title: 'Holiday Name', defaultContent: '-' },            
                     { data: 'isNationalHoliday', title: 'National Holiday', className: 'text-center',
                         render: function (data) {
                             return data
                                 ? '<span class="badge bg-danger">Yes</span>'
                                 : '<span class="badge bg-success">No</span>';
                         }
                     },
                     {
                         data: null,
                         title: 'Action',
                         orderable: false,
                         searchable: false,
                         className: 'text-center action-col',
                         width: '100px',
                         render: function (data, type, row) {
                             return `
                                 <div class="d-flex justify-content-center align-items-center gap-2">
                                     <a href="javascript:void(0)"
                                        onclick="editRow('${row.id}')"
                                        title="Edit">
                                         <i class="fa-solid fa-pen-to-square text-primary"></i>
                                     </a>
                                     <a href="javascript:void(0)"
                                        onclick="confirmDelete(() => deleteRow('${row.id}'))"
                                        title="Delete">
                                         <i class="fa-solid fa-trash text-danger"></i>
                                     </a> 
                                 </div>
                             `;
                         }
                     }
                 ] ,
                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    {
                        extend: 'csvHtml5',
                        className: 'btn-export-csv d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn-export-pdf d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    }
                ]
            });
            
            $('#csv-export').on('click', function () {
                $('.btn-export-csv').trigger('click');
            });

            $('#pdf-export').on('click', function () {
                $('.btn-export-pdf').trigger('click');
            });

            $('#add-new').on('click', function () {
                showModal();
            });
             $('#save-button').on('click', function () {
                saveHoliday();
            });
        });

        function saveHoliday() {
            const form = $('#holidayForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Add", "Holiday")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Company Holiday');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }

        function editRow(id) {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetData", "Holiday")',
                data: { id: id },
                success: function (data) {
                    if (!data) {
                        notify.warning('Holiday not found');
                        return;
                    }
             
                    $('#Item_Id').val(data.id); 
                    if (data.holidayDate) {
                        var cleanDate = data.holidayDate.split('T')[0];
                        $('#Item_HolidayDate').val(cleanDate);
                    }
                      
                    $('#Item_HolidayName').val(data.holidayName);  $('#chkNationalHoliday').prop('checked', data.isNationalHoliday); 
                    showModal(data.id);
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to retrieve Company Holiday');
                }
            });
        } 
        function deleteRow(id) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("Delete", "Holiday")',
                data: {
                    id: id
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Company Holiday');
                }
            });
        }
        function resetForm() {
            $('#holidayForm')[0].reset();
        }
    </script>
}
