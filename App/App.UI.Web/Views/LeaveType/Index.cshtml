@using App.Domain.Models
@using App.Domain.Models.Dto.Masters
@model PageModel<LeaveTypeDto>
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
}
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">

                <div class="d-flex align-items-center">

                    <h6 class="mb-0 fw-semibold">
                        Existing @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>

                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>

                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>
                    </div>
                </div>
            </div>

            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade"
     id="LeaveTypeModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa-solid fa-building me-2"></i>
                    <span id="modalTitle">
                        Add @Model.Title
                    </span>
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="LeaveTypeForm"
                      asp-action="Save"
                      method="post"
                      enctype="multipart/form-data"
                      autocomplete="off">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Mode)
                    @Html.HiddenFor(model => model.Title)        
                    
                    <div class="row g-3">                    
                        <div class="col-md-12">
                            <label asp-for="Item.LeaveCode" class="form-label fw-semibold"></label>
                            <input asp-for="Item.LeaveCode" asp-key="true" class="form-control" placeholder="e.g. SL, PL, etc" />
                            <span asp-validation-for="Item.LeaveCode" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Item.LeaveName" class="form-label fw-semibold"></label>
                            <input asp-for="Item.LeaveName" class="form-control" placeholder="e.g. Sick Leave, Paid Leave, etc" />
                            <span asp-validation-for="Item.LeaveName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mt-3">
                            <label asp-for="Item.DefaultAnnualQuota" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calculator"></i></span>
                                <input asp-for="Item.DefaultAnnualQuota" 
                                        type="number" 
                                        min="1" 
                                        class="form-control numeric-only" 
                                        placeholder="e.g. 12" />
                            </div>
                            <span asp-validation-for="Item.DefaultAnnualQuota" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12 mt-3">
                            <div class="form-check form-switch d-flex align-items-center gap-2 ps-0">
                                <input asp-for="Item.IsPaid" class="form-check-input ms-0 me-1" type="checkbox" role="switch" />
                                <label asp-for="Item.IsPaid" class="form-check-label fw-semibold mb-0" style="cursor: pointer;"></label>
                            </div>
                        </div>

                        <div class="col-md-12 mt-2">
                            <div class="form-check form-switch d-flex align-items-center gap-2 ps-0">
                                <input asp-for="Item.IsActive" class="form-check-input ms-0 me-1" type="checkbox" role="switch" />
                                <label asp-for="Item.IsActive" class="form-check-label fw-semibold mb-0" style="cursor: pointer;"></label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        onclick="resetForm()">
                    <i class="fa-solid fa-rotate-left me-1"></i>
                    Reset
                </button>
                <button id="save-button"
                        type="button"
                        class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>
                    Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('LeaveTypeModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            setReadonly(false);
            if (modal) {
                modal.hide();
            }
        }
        function showModal(code) {
            $('#modalTitle').text(
                code ? 'Edit Leave Type' : 'Add Leave Type'
            );

            setReadonly(code ? true : false);
            const modal = new bootstrap.Modal(
                document.getElementById('LeaveTypeModal')
            );
            modal.show();
        }
        $(document).ready(function () {
            // Mencegah spasi pada input Leave Code
            $('#Item_LeaveCode').on('keydown', function (e) {
                if (e.key === " ") {
                    e.preventDefault();
                }
            });

            // Otomatis ubah huruf kecil menjadi HURUF BESAR saat mengetik
            // dan menghapus spasi jika user melakukan copy-paste
            $('#Item_LeaveCode').on('input', function () {
                this.value = this.value.toUpperCase().replace(/\s+/g, '');
            });

            const table =  $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,
                ajax: {
                    url: '@Url.Action("GetList", "LeaveType")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;
                        notify.error('Failed to load Leave Type data');
                    }
                },
                columnDefs: [
                    {
                        targets: -1,
                        className: 'not-export'
                    }
                ],
                 columns: [
                     { data: 'leaveCode', title: 'Leave Code', defaultContent: '-' },
                     { data: 'leaveName', title: 'Leave Name', defaultContent: '-' },
                     {
                        data: 'isPaid',
                        title: 'Is Paid',
                        className: 'text-center',
                        render: function (data) {
                            return data
                                ? '<span class="badge bg-success">Yes</span>'
                                : '<span class="badge bg-secondary">No</span>';
                        }
                     },
                     {
                        data: 'isActive',
                        title: 'Is Active',
                        className: 'text-center',
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row) {
                            const checked = data ? 'checked' : '';
                            return `
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input status-switch" type="checkbox" role="switch" ${checked}
                                    onclick="confirmStatusChange('${row.leaveCode}', this)">
                                </div>
                            `;
                        }
                     },
                     {
                         data: null,
                         title: 'Action',
                         orderable: false,
                         searchable: false,
                         className: 'text-center action-col',
                         width: '100px',
                         render: function (data, type, row) {
                             return `
                                 <div class="d-flex justify-content-center align-items-center gap-2">
                                     <a href="javascript:void(0)"
                                        onclick="editRow('${row.leaveCode}')"
                                        title="Edit">
                                         <i class="fa-solid fa-pen-to-square text-primary"></i>
                                     </a>
                                     <a href="javascript:void(0)"
                                        onclick="confirmDelete(() => deleteRow('${row.leaveCode}'))"
                                        title="Delete">
                                         <i class="fa-solid fa-trash text-danger"></i>
                                     </a>
                                 </div>
                             `;
                         }
                     }
                 ] ,
                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    {
                        extend: 'csvHtml5',
                        className: 'btn-export-csv d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn-export-pdf d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    }
                ]
            });

            $('#csv-export').on('click', function () {
                $('.btn-export-csv').trigger('click');
            });

            $('#pdf-export').on('click', function () {
                $('.btn-export-pdf').trigger('click');
            });

            $('#add-new').on('click', function () {
                showModal();
            });
             $('#save-button').on('click', function () {
                saveLeaveType();
            });
        });

        function confirmStatusChange(leaveCode, element) {
            const isChecked = $(element).is(':checked');
            const statusText = isChecked ? 'ACTIVATE' : 'DEACTIVATE';
            const alertClass = isChecked ? 'text-success' : 'text-danger';

            Swal.fire({
                title: 'Are you sure?',
                html: `You are about to <b class="${alertClass}">${statusText}</b> Leave Code: <b>${leaveCode}</b>.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: isChecked ? '#28a745' : '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, change it!',
                cancelButtonText: 'Cancel',
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    executeStatusUpdate(leaveCode, isChecked, element);
                } else {
                    $(element).prop('checked', !isChecked);
                }
            });
        }

        function executeStatusUpdate(leaveCode, isChecked, element) {
            $.ajax({
                type: 'POST',
                url: '/LeaveType/UpdateStatus',
                data: {
                    code: leaveCode,
                    isActive: isChecked
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message || 'Status updated successfully.');
                    } else {
                        notify.warning(response.message || 'Failed to update status.');
                        // Kembalikan posisi switch jika ditolak oleh server backend
                        $(element).prop('checked', !isChecked);
                    }
                },
                error: function () {
                    notify.error('An error occurred while communicating with the server.');
                    // Kembalikan posisi switch jika terjadi error jaringan / 500
                    $(element).prop('checked', !isChecked);
                }
            });
        }

        function saveLeaveType() {
            const form = $('#LeaveTypeForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("SaveAsync", "LeaveType")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Leave Type');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }

        function editRow(code) {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetData", "LeaveType")',
                data: { code: code },
                success: function (data) {
                    if (!data) {
                        notify.warning('Leave Type not found');
                        return;
                    }             
                    $('#Item_LeaveCode').val(data.leaveCode);                    
                    $('#Item_LeaveName').val(data.leaveName);                      
                    showModal(data.leaveCode);
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to retrieve Leave Type');
                }
            });
        } 
        function deleteRow(code) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("Delete", "LeaveType")',
                data: {
                    code: code
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Leave Type');
                }
            });
        }
        function resetForm() {
            $('#LeaveTypeForm')[0].reset();
        }
    </script>
}