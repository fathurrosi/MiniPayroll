@using App.Domain.Models
@using App.Domain.Models.Dto
@using App.Domain.Models.Dto.Masters
@model PageModel<OvertimeTypeDto>
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
}

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">

                <div class="d-flex align-items-center">

                    <h6 class="mb-0 fw-semibold">
                        Existing @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>

                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>

                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>

                    </div>

                </div>

            </div>
            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
     
</div>
 
<div class="modal fade"
     id="overtimeTypeModal"
     tabindex="-1"
     aria-labelledby="overtimeTypeModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content border-0 shadow">

            <div class="modal-header">

                <h5 class="modal-title fw-bold"
                    id="overtimeTypeModalLabel">

                    <i class="bi bi-stopwatch text-primary me-2"></i>

                    <span id="modalTitle">
                        Add @Model.Title
                    </span>

                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <form id="overtimeTypeForm"
                      asp-action="Save"
                      method="post"
                      autocomplete="off">

                    @Html.AntiForgeryToken()

                    @Html.HiddenFor(m => m.Mode)
                    @Html.HiddenFor(m => m.Title)
 

                    <div class="row g-3">

                        <div class="col-md-4">

                            <label asp-for="Item.OvertimeCode"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Item.OvertimeCode" asp-key="true"
                                   class="form-control text-uppercase" />

                            <span asp-validation-for="Item.OvertimeCode"
                                  class="text-danger small"></span>

                        </div>

                        <div class="col-md-8">

                            <label asp-for="Item.OvertimeName"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Item.OvertimeName"
                                   class="form-control"
                                   placeholder="Working Day" />

                            <span asp-validation-for="Item.OvertimeName"
                                  class="text-danger small"></span>

                        </div>

                        <div class="col-md-12">

                            <label class="form-label fw-semibold">

                                Applies To

                            </label>

                            <select asp-for="Item.OvertimeCategory"
                                    class="form-select">

                                <option value="">-- Select Category --</option>

                                <option value="WorkingDay">
                                    🏢 Working Day
                                </option>

                                <option value="RestDay">
                                    🛌 Rest Day
                                </option>

                                <option value="PublicHoliday">
                                    🎉 Public Holiday
                                </option>

                            </select>

                        </div>

                        <div class="col-md-12">

                            <label asp-for="Item.Description"
                                   class="form-label fw-semibold">
                            </label>

                            <textarea asp-for="Item.Description"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Description..."></textarea>

                        </div>

                        <div class="col-md-12">

                            <div class="form-check form-switch">

                                <input asp-for="Item.IsActive"
                                       class="form-check-input" />

                                <label asp-for="Item.IsActive"
                                       class="form-check-label">
                                </label>

                            </div>

                        </div>

                    </div>

                </form>

            </div>

            <div class="modal-footer">

                <button class="btn btn-light"
                        type="button"
                        onclick="resetForm()">

                    <i class="bi bi-arrow-clockwise"></i>

                    Reset

                </button>

                <button id="save-button"
                        class="btn btn-primary"
                        type="button">

                    <i class="bi bi-check-circle"></i>

                    Save

                </button>

            </div>

        </div>

    </div>

</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('overtimeTypeModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            setReadonly(false);
            if (modal) {
                modal.hide();
            }
        }
        function showModal(id) {
            $('#modalTitle').text(
                id > 0 ? 'Edit overtimeType' : 'Add overtimeType'
            );

            setReadonly(id > 0 ? true : false);
            const modal = new bootstrap.Modal(
                document.getElementById('overtimeTypeModal')
            );
            modal.show();
        }
        $(document).ready(function () {
             $('#logoFile').on('change', function () {
                 const file = this.files[0];
                 const preview = document.getElementById('logoPreview');
                 if (!file) {
                     preview.style.display = 'none';
                     return;
                 }
                 preview.src = URL.createObjectURL(file);
                 preview.style.display = 'block';
            });
            const table = $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,
                order: [[0, 'asc']],

                ajax: {
                    url: '@Url.Action("GetList", "OvertimeType")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;

                        notify.error("Failed to load overtime types.");
                    }
                },

                columnDefs: [
                    {
                        targets: -1,
                        className: "not-export"
                    }
                ],

                columns: [

                    {
                        data: "overtimeCode",
                        title: "Code",
                        width: "80px",
                        render: function (data) {
                            return `<span class="fw-bold">${data}</span>`;
                        }
                    },

                    {
                        data: "overtimeName",
                        title: "Overtime Type",
                        render: function (data, type, row) {

                            return `
                                <div class="fw-semibold">
                                    ${data}
                                </div>
                                <small class="text-muted">
                                    ${row.description ?? ""}
                                </small>
                            `;
                        }
                    },

                    {
                        data: "overtimeCategory",
                        title: "Category",
                        className: "text-center",
                        width: "170px",
                        render: function (data) {

                             switch ((data || "").toUpperCase()) {


                                case "WORKINGDAY":
                                    return `<span class="badge bg-primary">
                                                <i class="bi bi-building"></i>
                                                Working Day
                                            </span>`;

                                case "RESTDAY":
                                    return `<span class="badge bg-warning text-dark">
                                                <i class="bi bi-moon"></i>
                                                Rest Day
                                            </span>`;

                                case "PUBLICHOLIDAY":
                                    return `<span class="badge bg-success">
                                                <i class="bi bi-calendar-event"></i>
                                                Public Holiday
                                            </span>`;

                                default:
                                    return `<span class="badge bg-secondary">
                                                Unknown
                                            </span>`;
                            }

                        }
                    },

                    {
                        data: "isActive",
                        title: "Status",
                        width: "90px",
                        className: "text-center",
                        render: function (data) {

                            return data
                                ? `<span class="badge bg-success">Active</span>`
                                : `<span class="badge bg-danger">Inactive</span>`;
                        }
                    },

                    {
                        data: null,
                        title: "Action",
                        orderable: false,
                        searchable: false,
                        className: "text-center action-col",
                        width: "90px",

                        render: function (data, type, row) {

                            return `

                                <div class="d-flex justify-content-center gap-2">

                                    <a href="javascript:void(0)"
                                       onclick="editRow(${row.id})"
                                       title="Edit">

                                        <i class="fa-solid fa-pen-to-square text-primary"></i>

                                    </a>

                                    <a href="javascript:void(0)"
                                       onclick="confirmDelete(() => deleteRow(${row.id}))"
                                       title="Delete">

                                        <i class="fa-solid fa-trash text-danger"></i>

                                    </a>

                                </div>

                            `;
                        }
                    }

                ],

                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",

                buttons: [

                    {
                        extend: "csvHtml5",
                        className: "btn-export-csv d-none",
                        title: "@Model.Title",
                        exportOptions: {
                            columns: ":not(.not-export)"
                        }
                    },

                    {
                        extend: "pdfHtml5",
                        className: "btn-export-pdf d-none",
                        title: "@Model.Title",
                        exportOptions: {
                            columns: ":not(.not-export)"
                        }
                    }

                ]
            });
            
            $('#csv-export').on('click', function () {
                $('.btn-export-csv').trigger('click');
            });

            $('#pdf-export').on('click', function () {
                $('.btn-export-pdf').trigger('click');
            });

            $('#add-new').on('click', function () {
                showModal();
            });
             $('#save-button').on('click', function () {
                saveovertimeType();
            });
        });

        function saveovertimeType() {
            const form = $('#overtimeTypeForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Add", "overtimeType")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Company overtimeType');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }

        function editRow(id) {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetData", "overtimeType")',
                data: { id: id },
                success: function (data) {
                    if (!data) {
                        notify.warning('overtimeType not found');
                        return;
                    }
             
                    $('#Item_Id').val(data.id); 
                    if (data.overtimeTypeDate) {
                        var cleanDate = data.overtimeTypeDate.split('T')[0];
                        $('#Item_overtimeTypeDate').val(cleanDate);
                    }
                      
                    $('#Item_overtimeTypeName').val(data.overtimeTypeName);  $('#chkNationalovertimeType').prop('checked', data.isNationalovertimeType); 
                    showModal(data.id);
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to retrieve Company overtimeType');
                }
            });
        } 
        function deleteRow(id) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("Delete", "overtimeType")',
                data: {
                    id: id
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Company overtimeType');
                }
            });
        }
        function resetForm() {
            $('#overtimeTypeForm')[0].reset();
        }
    </script>
}
