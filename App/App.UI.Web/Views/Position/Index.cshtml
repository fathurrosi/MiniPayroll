@using App.Domain.Models
@using App.Domain.Models.Dto
@using App.Domain.Models.Dto.Masters
@model PageModel<PositionDto>
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
}

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">

                <div class="d-flex align-items-center">

                    <h6 class="mb-0 fw-semibold">
                        Existing @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>

                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>

                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>

                    </div>

                </div>

            </div>
            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
     
</div>
 
<div class="modal fade"
     id="PositionModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa-solid fa-building me-2"></i>
                    <span id="modalTitle">
                        Add @Model.Title
                    </span>
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="PositionForm"
                      asp-action="Save"
                      method="post"
                      enctype="multipart/form-data"
                      autocomplete="off">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Mode)
                    @Html.HiddenFor(model => model.Title)
                              
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Item.PositionCode" 
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.PositionCode" asp-key="true" id="Item_PositionCodes"
                                   class="form-control"
                                   placeholder="e.g. SD" />
                            <span asp-validation-for="Item.PositionCode"
                                  class="text-danger small"></span>
                        </div>

                   
                        <div class="col-md-12">
                            <label asp-for="Item.PositionName"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.PositionName"
                                   class="form-control"
                                   placeholder="e.g. Senior Developer" />
                            <span asp-validation-for="Item.PositionName"
                                  class="text-danger small"></span>
                        </div>
 
                        <div class="col-md-12 mt-2">
                            <div class="form-check form-switch d-flex align-items-center gap-3 ps-0">
                                <input asp-for="Item.IsActive" id="Item_IsActive" class="form-check-input ms-0" type="checkbox" role="switch" style="cursor: pointer;" />
                                <label asp-for="Item.IsActive" class="form-check-label fw-semibold" style="cursor: pointer;"></label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        onclick="resetForm()">
                    <i class="fa-solid fa-rotate-left me-1"></i>
                    Reset
                </button>
                <button id="save-button"
                        type="button"
                        class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('PositionModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            setReadonly(false);
            if (modal) {
                modal.hide();
            }
        }
        function showModal(code) {
            $('#modalTitle').text(
                code ? 'Edit Position' : 'Add Position'
            );

            setReadonly(code ? true : false);
            const modal = new bootstrap.Modal(
                document.getElementById('PositionModal')
            );
            modal.show();
        }
        $(document).ready(function () {

            // Validasi input manual BranchCode
            $('#Item_PositionCodes').on('keydown', function (e) {
                if (e.key === " ") {
                    e.preventDefault();
                }
            });

            $('#Item_PositionCodes').on('input', function () {
                this.value = this.value.toUpperCase().replace(/\s+/g, '');
            });

            const table =  $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false, 
                ajax: {
                    url: '@Url.Action("GetList", "Position")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;
                        notify.error('Failed to load Position data');
                    }
                },
                columnDefs: [
                    {
                        targets: -1,
                        className: 'not-export'
                    }
                ],
                 columns: [ 
                     { data: 'positionCode', title: 'Position Code', defaultContent: '-' },
                     { data: 'positionName', title: 'Position Name', defaultContent: '-' },
                     {
                        data: 'isActive',
                        title: 'Is Active',
                        className: 'text-center',
                        orderable: false,
                        searchable: false,
                        render: function (data, type, row) {
                            const checked = data ? 'checked' : '';
                            return `
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input status-switch" type="checkbox" role="switch" ${checked}
                                    onclick="confirmStatusChange('${row.positionCode}', this)">
                                </div>
                            `;
                        }
                     },
                     {
                         data: null,
                         title: 'Action',
                         orderable: false,
                         searchable: false,
                         className: 'text-center action-col',
                         width: '100px',
                         render: function (data, type, row) {
                             return `
                                 <div class="d-flex justify-content-center align-items-center gap-2">
                                     <a href="javascript:void(0)"
                                        onclick="editRow('${row.positionCode}')"
                                        title="Edit">
                                         <i class="fa-solid fa-pen-to-square text-primary"></i>
                                     </a>
                                     <a href="javascript:void(0)"
                                        onclick="confirmDelete(() => deleteRow('${row.positionCode}'))"
                                        title="Delete">
                                         <i class="fa-solid fa-trash text-danger"></i>
                                     </a>
                                 </div>
                             `;
                         }
                     }
                 ] ,
                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    {
                        extend: 'csvHtml5',
                        className: 'btn-export-csv d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn-export-pdf d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    }
                ]
            });
            
            $('#csv-export').on('click', function () {
                $('.btn-export-csv').trigger('click');
            });

            $('#pdf-export').on('click', function () {
                $('.btn-export-pdf').trigger('click');
            });

            $('#add-new').on('click', function () {
                showModal();
            });
             $('#save-button').on('click', function () {
                savePosition();
            });
        });


        function confirmStatusChange(positionCode, element) {
            const isChecked = $(element).is(':checked');
            const statusText = isChecked ? 'ACTIVATE' : 'DEACTIVATE';
            const alertClass = isChecked ? 'text-success' : 'text-danger';

            Swal.fire({
                title: 'Are you sure?',
                html: `You are about to <b class="${alertClass}">${statusText}</b> Position Code: <b>${positionCode}</b>.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: isChecked ? '#28a745' : '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, change it!',
                cancelButtonText: 'Cancel',
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    executeStatusUpdate(positionCode, isChecked, element);
                } else {
                    $(element).prop('checked', !isChecked);
                }
            });
        }

        function executeStatusUpdate(positionCode, isChecked, element) {
            $.ajax({
                type: 'POST',
                url: '/Position/UpdateStatus',
                data: {
                    code: positionCode,
                    isActive: isChecked
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message || 'Status updated successfully.');
                    } else {
                        notify.warning(response.message || 'Failed to update status.');
                        $(element).prop('checked', !isChecked);
                    }
                },
                error: function () {
                    notify.error('An error occurred while communicating with the server.');
                    $(element).prop('checked', !isChecked);
                }
            });
        }

        function savePosition() {
            const form = $('#PositionForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Add", "Position")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Company Position');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }

        function editRow(code) {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetData", "Position")',
                data: { code: code },
                success: function (data) {
                    if (!data) {
                        notify.warning('Position not found');
                        return;
                    }
             
                    $('#Item_PositionCode').val(data.positionCode);                       
                    $('#Item_PositionName').val(data.positionName); 
                    showModal(data.positionCode);
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to retrieve Company Position');
                }
            });
        }
        function deleteRow(code) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("Delete", "Position")',
                data: {
                    code: code
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Company Position');
                }
            });
        }
        function resetForm() {
            $('#PositionForm')[0].reset();
        }
    </script>
}
