@using App.Domain.Models
@using App.Domain.Models.Dto
@model PageModel<ProfileDto>
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
}

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">

                <div class="d-flex align-items-center">

                    <h6 class="mb-0 fw-semibold">
                        Existing @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">

                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>

                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>

                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>

                    </div>

                </div>

            </div>
            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
     
</div>
 
<div class="modal fade"
     id="companyProfileModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-scrollable">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    <i class="fa-solid fa-building me-2"></i>
                    <span id="modalTitle">
                        Add @Model.Title
                    </span>
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>

            </div>

            <div class="modal-body">

                <form id="companyProfileForm"
                      asp-action="Save"
                      method="post"
                      enctype="multipart/form-data"
                      autocomplete="off">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Mode)
                    @Html.HiddenFor(model => model.Title)
                    @Html.HiddenFor(model => model.Item.CompanyProfileId)                
                    <div class="row g-3">
                       
                        <!-- Company Name -->
                        <div class="col-md-6">
                            <label asp-for="Item.CompanyName"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.CompanyName"
                                   class="form-control"
                                   placeholder="Company Name" />
                            <span asp-validation-for="Item.CompanyName"
                                  class="text-danger small"></span>
                        </div>
                        <!-- Phone Number -->
                        <div class="col-md-6">
                            <label asp-for="Item.PhoneNumber"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.PhoneNumber"
                                   class="form-control"
                                   placeholder="+62xxxxxxxxxx" />
                            <span asp-validation-for="Item.PhoneNumber"
                                  class="text-danger small"></span>
                        </div>
                        <!-- Email -->
                        <div class="col-md-6">
                            <label asp-for="Item.Email"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.Email"
                                   type="email"
                                   class="form-control"
                                   placeholder="company@example.com" />
                            <span asp-validation-for="Item.Email"
                                  class="text-danger small"></span>
                        </div>

                        <!-- Website -->
                        <div class="col-md-6">
                            <label asp-for="Item.Website"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.Website"
                                   class="form-control"
                                   placeholder="https://www.company.com" />
                            <span asp-validation-for="Item.Website"
                                  class="text-danger small"></span>
                        </div>
                        <!-- Tax Number -->
                        <div class="col-md-6">
                            <label asp-for="Item.TaxNumber"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="Item.TaxNumber"
                                   class="form-control"
                                   placeholder="NPWP / Tax Number" />
                            <span asp-validation-for="Item.TaxNumber"
                                  class="text-danger small"></span>
                        </div>

                        <!-- Status -->
                        <div class="col-md-6">
                            <label asp-for="Item.IsActive"
                                   class="form-label fw-semibold"></label>
                            <select asp-for="Item.IsActive"
                                    class="form-select">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                            <span asp-validation-for="Item.IsActive"
                                  class="text-danger small"></span>
                        </div>

                        <!-- Logo Upload -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                Company Logo
                            </label>

                            <input type="file"
                                   id="logoFile"
                                   name="LogoFile"
                                   accept=".png,.jpg,.jpeg,.svg"
                                   class="form-control" />

                            @Html.HiddenFor(model => model.Item.LogoFileName)
                            @Html.HiddenFor(model => model.Item.LogoFilePath)

                            <span asp-validation-for="Item.LogoFilePath"
                                  class="text-danger small"></span>

                            <div class="mt-3">
                                <img id="logoPreview"
                                     src="@Model.Item.LogoFilePath"
                                     alt="Logo Preview"
                                     style="max-height:150px; max-width:300px; @(string.IsNullOrEmpty(Model.Item.LogoFilePath) ? "display:none;" : "")" />
                            </div>
                        </div>

                        <!-- Company Address -->
                        <div class="col-6">
                            <label asp-for="Item.CompanyAddress"
                                   class="form-label fw-semibold"></label>
                            <textarea asp-for="Item.CompanyAddress"
                                      rows="4"
                                      class="form-control"
                                      placeholder="Company Address"></textarea>
                            <span asp-validation-for="Item.CompanyAddress"
                                  class="text-danger small"></span>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        onclick="resetForm()">
                    <i class="fa-solid fa-rotate-left me-1"></i>
                    Reset
                </button>
                <button id="save-button"
                        type="button"
                        class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('companyProfileModal');
            const modal = bootstrap.Modal.getInstance(modalElement);

            if (modal) {
                modal.hide();
            }
        }
        function showAddModal() {
            // resetForm();
            $('#modalTitle').text('Add Company Profile');
            const modal = new bootstrap.Modal(
                document.getElementById('companyProfileModal')
            );
            modal.show();
        }
        $(document).ready(function () {
             $('#logoFile').on('change', function () {
                 const file = this.files[0];
                 const preview = document.getElementById('logoPreview');
                 if (!file) {
                     preview.style.display = 'none';
                     return;
                 }
                 preview.src = URL.createObjectURL(file);
                 preview.style.display = 'block';
            });
            const form = $('#addProfileForm'); 

            // ================================
            // DataTable Initialization
            // ================================
            const table =  $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,

                ajax: {
                    url: '@Url.Action("GetList", "Profile")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;
                        notify.error('Failed to load Profile data');
                    }
                },
             columns: [
                 { data: 'companyName', title: 'Company Name' },
                 { data: 'phoneNumber', title: 'Phone Number', defaultContent: '-' },
                 { data: 'email', title: 'Email', defaultContent: '-' },
                 { data: 'website', title: 'Website', defaultContent: '-',
                     render: function (data) {
                         if (!data)
                             return '-';
                         return `<a href="${data}" target="_blank">${data}</a>`;
                     }
                 },
                 { data: 'taxNumber', title: 'Tax Number', defaultContent: '-' },
                 { data: 'isActive', title: 'Status', className: 'text-center',
                     render: function (data) {
                         return data
                             ? '<span class="badge bg-success">Active</span>'
                             : '<span class="badge bg-danger">Inactive</span>';
                     }
                 },
                 {
                     data: null,
                     title: 'Action',
                     orderable: false,
                     searchable: false,
                     className: 'text-center action-col',
                     width: '100px',
                     render: function (data, type, row) {
                         return `
                             <div class="d-flex justify-content-center align-items-center gap-2">
             
                                 <a href="javascript:void(0)"
                                    onclick="editRow('${row.companyProfileId}')"
                                    title="Edit">
                                     <i class="fa-solid fa-pen-to-square text-primary"></i>
                                 </a>
             
                                 <a href="javascript:void(0)"
                                    onclick="confirmDelete(() => deleteRow('${row.companyProfileId}'))"
                                    title="Delete">
                                     <i class="fa-solid fa-trash text-danger"></i>
                                 </a>
             
                             </div>
                         `;
                     }
                 }
             ] ,

                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    {
                        extend: 'csvHtml5',
                        title: '@Model.Title',
                        className: 'd-none'
                    },
                    {
                        extend: 'pdfHtml5',
                        title: '@Model.Title',
                        className: 'd-none'
                    }
                ]
            });
            // ================================
            // Export Buttons
            // ================================
            $('#csv-export').on('click', function () {
                alert('csv-export');
                const table = $('#main-table').DataTable();
                table.button('.buttons-csv').trigger();
            });
            $('#pdf-export').on('click', function () {
                alert('pdf-export');
                const table = $('#main-table').DataTable();
                table.button('.buttons-pdf').trigger();
            });
            $('#add-new').on('click', function () {
                showAddModal();
            });
             $('#save-button').on('click', function () {
                saveCompanyProfile();
            });
        });

        function saveCompanyProfile() {
            const form = $('#companyProfileForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("AddProfile", "Profile")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#btnSave').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message || 'Company Profile saved successfully');
                        if (response.companyProfileId) {
                            $('#Item_CompanyProfileId').val(response.companyProfileId);
                        }
                        $('#companyProfileTable').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message || 'Failed to save Company Profile');
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Company Profile');
                },
                complete: function () {
                    $('#btnSave').prop('disabled', false);
                }
            });
        }
        function editRow(id) {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetCompanyProfile", "CompanyProfile")',
                data: { id: id },
                success: function (data) {
                    if (!data) {
                        notify.warning('Company Profile not found');
                        return;
                    }
                    $('#Item_CompanyProfileId').val(data.companyProfileId);
                    $('#Item_CompanyName').val(data.companyName);
                    $('#Item_CompanyAddress').val(data.companyAddress);
                    $('#Item_PhoneNumber').val(data.phoneNumber);
                    $('#Item_Email').val(data.email);
                    $('#Item_Website').val(data.website);
                    $('#Item_TaxNumber').val(data.taxNumber);
                    $('#Item_IsActive').val(data.isActive.toString());
                    $('#Item_LogoFileName').val(data.logoFileName);
                    $('#Item_LogoFilePath').val(data.logoFilePath);
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                    notify.info('Company Profile loaded');
                },

                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to retrieve Company Profile');
                }
            });
        }

        function deleteRow(id) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("DeleteProfile", "Profile")',
                data: {
                    id: id
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Company Profile');
                }
            });
        }
        function resetForm() {
            $('#companyProfileForm')[0].reset();
            $('#Item_CompanyProfileId').val('');
            $('#Item_LogoFileName').val('');
            $('#Item_LogoFilePath').val('');
        }
    </script>
}
