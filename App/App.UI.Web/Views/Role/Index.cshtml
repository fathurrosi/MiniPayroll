@using App.Domain.Enums
@using App.Domain.Models
@using App.Domain.Models.Dto
@using App.Domain.Models.Dto.Masters
@model PageModel<RoleDto>
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
}

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">

                <div class="d-flex align-items-center">

                    <h6 class="mb-0 fw-semibold">
                        Existing @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>

                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>

                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>

                    </div>

                </div>

            </div>
            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
     
</div>
 
<div class="modal fade"
     id="RoleModal"
     tabindex="-1"
     aria-labelledby="RoleModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"
                    id="RoleModalLabel">
                    <i class="bi bi-stopwatch text-primary me-2"></i>
                    <span id="modalTitle">
                        Add @Model.Title
                    </span>
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>
            <div class="modal-body">
                <form id="RoleForm" asp-action="Save"
                      method="post" autocomplete="off">

                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.Mode)
                    @Html.HiddenFor(m => m.Title)

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="row g-3">

                        <!-- Role Code -->
                        <div class="col-md-6">
                            <label asp-for="Item.RoleCode"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Item.RoleCode"
                                   asp-key="true"
                                   maxlength="100"
                                   class="form-control text-uppercase"
                                   placeholder="Enter role code" />

                            <span asp-validation-for="Item.RoleCode"
                                  class="text-danger small">
                            </span>
                        </div>

                        <!-- Role Name -->
                        <div class="col-md-6">
                            <label asp-for="Item.RoleName"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Item.RoleName"
                                   maxlength="255"
                                   class="form-control"
                                   placeholder="Enter role name" />

                            <span asp-validation-for="Item.RoleName"
                                  class="text-danger small">
                            </span>
                        </div>

                        <!-- Description -->
                        <div class="col-md-12">
                            <label asp-for="Item.Description"
                                   class="form-label fw-semibold">
                            </label>

                            <textarea asp-for="Item.Description"
                                      rows="4"
                                      maxlength="500"
                                      class="form-control"
                                      placeholder="Enter role description"> </textarea>

                            <span asp-validation-for="Item.Description"
                                  class="text-danger small">
                            </span>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch">
                                <input asp-for="Item.IsDeleted"
                                       class="form-check-input"
                                       role="switch" />

                                <label asp-for="Item.IsDeleted"
                                       class="form-check-label fw-semibold">
                                    Mark as Deleted
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-light"
                        type="button"
                        onclick="resetForm()">
                    <i class="bi bi-arrow-clockwise"></i>
                    Reset
                </button>
                <button id="save-button"
                        class="btn btn-primary"
                        type="button">
                    <i class="bi bi-check-circle"></i>
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('RoleModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            setReadonly(false);
            if (modal) {
                modal.hide();
            }
        }
        function showModal(isEdit) {
            $('#modalTitle').text(
                isEdit ? 'Edit Role' : 'Add Role'
            );

            setReadonly(isEdit);
            const modal = new bootstrap.Modal(
                document.getElementById('RoleModal')
            );
            modal.show();
        }
        $(document).ready(function () {
             $('#logoFile').on('change', function () {
                 const file = this.files[0];
                 const preview = document.getElementById('logoPreview');
                 if (!file) {
                     preview.style.display = 'none';
                     return;
                 }
                 preview.src = URL.createObjectURL(file);
                 preview.style.display = 'block';
            });
            const table = $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,
                order: [[0, 'asc']],

                ajax: {
                    url: '@Url.Action("GetList", "Role")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;

                        notify.error("Failed to load Role types.");
                    }
                },

                columnDefs: [
                    {
                        targets: -1,
                        className: "not-export"
                    }
                ],

                columns: [

                    {
                        data: "roleCode",
                        title: "Code",
                        width: "80px",
                        render: function (data) {
                            return `<span class="fw-bold">${data}</span>`;
                        }
                    },

                    {
                        data: "roleName",
                        title: "Role Name",
                        render: function (data, type, row) {

                            return `
                                <div class="fw-semibold">
                                    ${data}
                                </div>
                                <small class="text-muted">
                                    ${row.description ?? ""}
                                </small>
                            `;
                        }
                    },
                    {
                        data: "isDeleted",
                        title: "Status",
                        width: "90px",
                        className: "text-center",
                        render: function (data) {

                            return data
                                ? `<span class="badge bg-danger">Yes</span>`
                                : `<span class="badge bg-success">No</span>`;
                        }
                    },

                    {
                        data: null,
                        title: "Action",
                        orderable: false,
                        searchable: false,
                        className: "text-center action-col",
                        width: "90px",

                        render: function (data, type, row) {

                            return `

                                <div class="d-flex justify-content-center gap-2">

                                    <a href="javascript:void(0)"
                                       onclick="editRow('${row.roleCode}')"
                                       title="Edit">

                                        <i class="fa-solid fa-pen-to-square text-primary"></i>

                                    </a>

                                    <a href="javascript:void(0)"
                                       onclick="confirmDelete(() => deleteRow('${row.roleCode}'))"
                                       title="Delete">

                                        <i class="fa-solid fa-trash text-danger"></i>

                                    </a>

                                </div>

                            `;
                        }
                    }

                ],

                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",

                buttons: [

                    {
                        extend: "csvHtml5",
                        className: "btn-export-csv d-none",
                        title: "@Model.Title",
                        exportOptions: {
                            columns: ":not(.not-export)"
                        }
                    },

                    {
                        extend: "pdfHtml5",
                        className: "btn-export-pdf d-none",
                        title: "@Model.Title",
                        exportOptions: {
                            columns: ":not(.not-export)"
                        }
                    }

                ]
            });
            
            $('#csv-export').on('click', function () {
                $('.btn-export-csv').trigger('click');
            });

            $('#pdf-export').on('click', function () {
                $('.btn-export-pdf').trigger('click');
            });

            $('#add-new').on('click', function () {
                showModal(false);
            });
             $('#save-button').on('click', function () {
                saveRole();
            });

            $('#Item_IsActive').prop('checked', data.isActive === true);
        });

        function saveRole() {
            const form = $('#RoleForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Add", "Role")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Company Role');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }

        function editRow(code) {

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetData", "Role")',
                data: { code: code},

                success: function (data) {

                    if (!data) {
                        notify.warning('Role type not found.');
                        return;
                    }

                    // Basic Information
                    $('#Item_RoleCode').val(data.roleCode);
                    $('#Item_RoleName').val(data.roleName);
                    $('#Item_Description').val(data.description);

                    // Category
                    //$('#Item_RoleCategory').val(data.RoleCategory);

                    // Status
                    $('#Item_IsDeleted').prop('checked', data.isDeleted);

                    showModal(true);
                },

                error: function (xhr) {

                    if (xhr.status === 401 || xhr.status === 403)
                        return;

                    notify.error('Failed to retrieve Role type.');

                }
            });

        }
        function deleteRow(code) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("Delete", "Role")',
                data: {
                    code: code
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Company Role');
                }
            });
        }
        function resetForm() {
            $('#RoleForm')[0].reset();
        }
    </script>
}
