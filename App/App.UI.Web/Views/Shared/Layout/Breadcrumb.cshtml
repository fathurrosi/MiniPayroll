<style type="text/css">
    /* Container */
    .breadcrumb-modern {
        background: #fff;
        padding: 10px 0;
        font-family: "Segoe UI", Arial, sans-serif;
        margin-left: 15px;
    }

        /* List */
        .breadcrumb-modern ol {
            margin: 0;
            padding: 0;
            list-style: none;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
        }

        /* Items */
        .breadcrumb-modern li {
            display: flex;
            align-items: center;
            font-size: 14px;
            font-weight: 400;
            line-height: 1;
        }

            /* Chevron separator */
            .breadcrumb-modern li + li::before {
                content: "›";
                color: #b8bec7;
                font-size: 18px;
                font-weight: 300;
                margin: 0 10px;
                position: relative;
                top: -1px;
            }

            /* Circle marker */
            .breadcrumb-modern li::after {
                display: none;
            }

            .breadcrumb-modern li a,
            .breadcrumb-modern li.active {
                display: flex;
                align-items: center;
            }

                /* Small outlined circle */
                .breadcrumb-modern li a::before,
                .breadcrumb-modern li.active::before {
                    content: "";
                    width: 11px;
                    height: 11px;
                    border: 2px solid #6fa8dc;
                    border-radius: 50%;
                    margin-right: 7px;
                    box-sizing: border-box;
                }

            /* Link style */
            .breadcrumb-modern li a {
                color: #3f7fc0;
                text-decoration: none;
                transition: color .15s ease;
            }

                .breadcrumb-modern li a:hover {
                    color: #2f6ca8;
                }

            /* Current page */
            .breadcrumb-modern li.active {
                color: #444;
                font-weight: 400;
            }

                /* Current page circle */
                .breadcrumb-modern li.active::before {
                    border-color: #4a4a4a;
                }

            /* Ellipsis item */
            .breadcrumb-modern li a[href="#"] {
                letter-spacing: 1px;
            }
</style>
<nav class="breadcrumb-modern" aria-label="breadcrumb">
    <ol>
        <li>
            @*      <a asp-controller="Home" asp-action="Index">Home</a> *@
            <a href="@Url.Action("Index", "Home")" class="text-dark p-2 rounded-circle d-inline-flex justify-content-center align-items-center" style="background-color: rgba(0,0,0,0.08); width: 28px; height: 28px;">
                <i class="fas fa-home" style="font-size: 0.75rem; color: #000000;"></i>
            </a>
        </li>

        <li>
            <a asp-controller="Category" asp-action="Index">Categories</a>
        </li>

        <li>
            <a asp-controller="Product" asp-action="Index">Products</a>
        </li>

        <li>
            <a href="#">...</a>
        </li>

        <li class="active">
            Product Details
        </li>
    </ol>
</nav>

