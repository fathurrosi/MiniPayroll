@using App.Domain.Models
@using App.Domain.Models.Dto
@model PageModel<ShiftDto>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">
                <div class="d-flex align-items-center">
                    <h6 class="mb-0 fw-semibold">
                        @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>
                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>

                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>
                         

                    </div>

                </div>

            </div>
            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade"
     id="ShiftModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa-solid fa-building me-2"></i>
                    <span id="modalTitle">
                        Add @Model.Title
                    </span>
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="shiftForm">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Mode)
                    @Html.HiddenFor(model => model.Title)
                    <input asp-for="Item.Id" type="hidden" asp-key="true" />
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label asp-for="Item.ShiftCode">
                                Shift Code <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Item.ShiftCode"
                                   class="form-control"
                                   placeholder="e.g., M, NIGHT12" />
                            <span asp-validation-for="Item.ShiftCode"
                                  class="text-danger"></span>
                        </div>

                        <div class="col-md-6 form-group">
                            <label asp-for="Item.ShiftName">
                                Shift Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Item.ShiftName"
                                   class="form-control"
                                   placeholder="e.g., Morning Shift" />
                            <span asp-validation-for="Item.ShiftName"
                                  class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label asp-for="Item.StartTime">
                                Start Time <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Item.StartTime"
                                   type="time"
                                   class="form-control" />
                            <span asp-validation-for="Item.StartTime"
                                  class="text-danger"></span>
                        </div>

                        <div class="col-md-6 form-group">
                            <label asp-for="Item.EndTime">
                                End Time <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Item.EndTime"
                                   type="time"
                                   class="form-control" />
                            <span asp-validation-for="Item.EndTime"
                                  class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label asp-for="Item.BreakStart"></label>
                            <input asp-for="Item.BreakStart"
                                   type="time"
                                   class="form-control" />
                            <span asp-validation-for="Item.BreakStart"
                                  class="text-danger"></span>
                        </div>

                        <div class="col-md-6 form-group">
                            <label asp-for="Item.BreakEnd"></label>
                            <input asp-for="Item.BreakEnd"
                                   type="time"
                                   class="form-control" />
                            <span asp-validation-for="Item.BreakEnd"
                                  class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3 form-group">
                            <label asp-for="Item.WorkingHours">
                                Working Hours <span class="text-danger">*</span>
                            </label>

                            <input asp-for="Item.WorkingHours"
                                   class="form-control"
                                   placeholder="8.00" />

                            <span asp-validation-for="Item.WorkingHours"
                                  class="text-danger"></span>
                        
                        </div>
                           
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <input asp-for="Item.IsOvernight"
                                   class="form-check-input"
                                   id="chkIsOvernight" />
                                       
                            <label asp-for="Item.IsOvernight"
                                   class="custom-control-label">
                                Crosses Midnight (Overnight)
                            </label>
                        </div>
                        <div class="col-md-6 form-group">
                            <input asp-for="Item.IsActive"
                                   class="form-check-input"
                                   id="chkIsActive" />
                                       
                            <label asp-for="Item.IsActive"
                                   class="custom-control-label">
                                Active
                            </label>
                        </div>
                        
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        onclick="resetForm()">
                    <i class="fa-solid fa-rotate-left me-1"></i>
                    Reset
                </button>
                <button id="save-button"
                        type="button"
                        class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk me-1"></i>
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('ShiftModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            setReadonly(false);
            if (modal) {
                modal.hide();
            }
        }
        function showModal(id) {
            $('#modalTitle').text(
                id > 0 ? 'Edit Shift' : 'Add Shift'
            );

            setReadonly(id > 0 ? true : false);
            const modal = new bootstrap.Modal(
                document.getElementById('ShiftModal')
            );
            modal.show();
        }

        function calculateTotalWorkingHours() {
            // Grab raw values (Format from type="time" is naturally 24-hour "HH:mm")
            const startTime = $('#Item_StartTime').val();
            const endTime = $('#Item_EndTime').val();
            const breakStart = $('#Item_BreakStart').val();
            const breakEnd = $('#Item_BreakEnd').val();
            const isOvernight = $('#chkIsOvernight').is(':checked');

            // Target field for total hours
            const $workingHoursField = $('#Item_WorkingHours');

            // Clear display if core fields are empty
            if (!startTime || !endTime) {
                $workingHoursField.val('');
                return;
            }

            // Helper: Convert "HH:mm" to total minutes from midnight
            function timeToMinutes(timeStr) {
                if (!timeStr) return null;
                const parts = timeStr.split(':');
                const hours = parseInt(parts[0], 10);
                const minutes = parseInt(parts[1], 10);
                return hours * 60 + minutes;
            }

            let startMin = timeToMinutes(startTime);
            let endMin = timeToMinutes(endTime);

            // --- Handle Overnight Shifts ---
            if (isOvernight || endMin <= startMin) {
                // If overnight is checked or logically ends on a lower hour number next day
                if (endMin <= startMin) {
                    endMin += 24 * 60; // Add a full day in minutes
                }
            }

            let totalShiftMinutes = endMin - startMin;
            let totalBreakMinutes = 0;

            // --- Process Break Times (If both exist) ---
            if (breakStart && breakEnd) {
                let bStartMin = timeToMinutes(breakStart);
                let bEndMin = timeToMinutes(breakEnd);

                // Shift break timeline if the shift itself crosses midnight
                if (bStartMin < startMin) bStartMin += 24 * 60;
                if (bEndMin < startMin) bEndMin += 24 * 60;
                if (bEndMin < bStartMin) bEndMin += 24 * 60;

                // Validations
                if (bStartMin < startMin || bEndMin > endMin) {
                    console.warn(
                        'Validation Warning: Break must fall within shift window.'
                    );
                    $workingHoursField.val('0.00');
                    return;
                }
                if (bEndMin < bStartMin) {
                    console.warn(
                        'Validation Warning: Break end time cannot precede break start time.'
                    );
                    $workingHoursField.val('0.00');
                    return;
                }

                totalBreakMinutes = bEndMin - bStartMin;
            }

            // --- Calculate Net Working Hours ---
            let netMinutes = totalShiftMinutes - totalBreakMinutes;

            if (netMinutes < 0) {
                $workingHoursField.val('0.00');
                return;
            }

            // Convert back to two decimal points
            let finalHours = (netMinutes / 60).toFixed(2);
            $workingHoursField.val(finalHours);
        }

        $(document).ready(function () {

            $('#Item_StartTime, #Item_EndTime, #Item_BreakStart, #Item_BreakEnd, #chkIsOvernight').on('change input', function () {
                calculateTotalWorkingHours();
            });

            const table =  $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,
                order: [[0, 'desc']],
                ajax: {
                    url: '@Url.Action("GetList", "Shift")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;
                        notify.error('Failed to load Shift data');
                    }
                },
                columnDefs: [
                    {
                        targets: -1,
                        className: 'not-export'
                    }
                ],
                 columns: [
                     { data: 'id', title: 'Id', defaultContent: '-', visible: false },
                     { data: 'shiftCode', title: 'Shift Code', defaultContent: '-' },
                     { data: 'shiftName', title: 'Shift Name', defaultContent: '-' },
                     { data: 'startTime', title: 'Start Time', defaultContent: '-' },
                     { data: 'endTime', title: 'End Time', defaultContent: '-' },
                     { data: 'breakStart', title: 'Break Start', defaultContent: '-' },
                     { data: 'breakEnd', title: 'Break End', defaultContent: '-' },
                     { data: 'workingHours', title: 'WorkingHours', defaultContent: '-' },
                     { data: 'isOvernight', title: 'Is Overnight', className: 'text-center',
                         render: function (data) {
                             return data
                                 ? '<span class="badge bg-success">Yes</span>'
                                 : '<span class="badge bg-Warning">No</span>';
                         }
                     },
                     { data: 'isActive', title: 'Is Active', className: 'text-center',
                         render: function (data) {
                             return data
                                 ? '<span class="badge bg-success">Active</span>'
                                 : '<span class="badge bg-danger">Inactive</span>';
                         }
                     },
                     {
                         data: null,
                         title: 'Action',
                         orderable: false,
                         searchable: false,
                         className: 'text-center action-col',
                         width: '100px',
                         render: function (data, type, row) {
                             return `
                                 <div class="d-flex justify-content-center align-items-center gap-2">
                                     <a href="javascript:void(0)"
                                        onclick="editRow('${row.id}')"
                                        title="Edit">
                                         <i class="fa-solid fa-pen-to-square text-primary"></i>
                                     </a>
                                     <a href="javascript:void(0)"
                                        onclick="confirmDelete(() => deleteRow('${row.id}'))"
                                        title="Delete">
                                         <i class="fa-solid fa-trash text-danger"></i>
                                     </a>
                                 </div>
                             `;
                         }
                     }
                 ] ,
                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    {
                        extend: 'csvHtml5',
                        className: 'btn-export-csv d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn-export-pdf d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    }
                ]
            });
            
            $('#csv-export').on('click', function () {
                $('.btn-export-csv').trigger('click');
            });

            $('#pdf-export').on('click', function () {
                $('.btn-export-pdf').trigger('click');
            });

            $('#add-new').on('click', function () {
                showModal();
            });
             $('#save-button').on('click', function () {
                saveShift();
            });
        });

        function saveShift() {
            const form = $('#shiftForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Add", "Shift")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Company Shift');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }
         
        function editRow(id) {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetData", "Shift")',
                data: { id: id },
                success: function (data) {

                    if (!data) {
                        notify.warning('Shift not found');
                        return;
                    }

                    $('#Item_Id').val(data.id);

                    $('#Item_ShiftCode').val(data.shiftCode);
                    $('#Item_ShiftName').val(data.shiftName);

                    $('#Item_StartTime').val(
                        data.startTime ? data.startTime.substring(0, 5) : ''
                    );

                    $('#Item_EndTime').val(
                        data.endTime ? data.endTime.substring(0, 5) : ''
                    );

                    $('#Item_BreakStart').val(
                        data.breakStart ? data.breakStart.substring(0, 5) : ''
                    );

                    $('#Item_BreakEnd').val(
                        data.breakEnd ? data.breakEnd.substring(0, 5) : ''
                    );

                    $('#Item_WorkingHours').val(data.workingHours);

                    $('#Item_IsOvernight').prop('checked', data.isOvernight);
                    $('#Item_IsActive').prop('checked', data.isActive);

                    showModal(data.id);
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403) {
                        return;
                    }

                    notify.error('Failed to retrieve Company Shift');
                }
            });
        }
        function deleteRow(id) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("Delete", "Shift")',
                data: {
                    id: id
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Company Shift');
                }
            });
        }
        function resetForm() {
            $('#shiftForm')[0].reset();
        }

    </script>
}