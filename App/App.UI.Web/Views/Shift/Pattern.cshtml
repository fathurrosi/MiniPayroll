@using App.Domain.Models
@using App.Domain.Models.Dto
@model PageModel<ShiftPatternDto>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">
                <div class="d-flex align-items-center">
                    <h6 class="mb-0 fw-semibold">
                        @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>

                        <a href="/Shift/Detail"
                               title="Add New" class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>   Add New
                        </a>
                         

                        <button class="btn btn-outline-success">
                            Export Excel
                        </button>
                        <button class="btn btn-outline-danger">
                            Export PDF
                        </button>

                    </div>

                </div>

            </div>
            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
 
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('ShiftModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            setReadonly(false);
            if (modal) {
                modal.hide();
            }
        }
        function showModal(id) {
            $('#modalTitle').text(
                id > 0 ? 'Edit Shift' : 'Add Shift'
            );

            setReadonly(id > 0 ? true : false);
            const modal = new bootstrap.Modal(
                document.getElementById('ShiftModal')
            );
            modal.show();
        }
        $(document).ready(function () {
            const table =  $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,
                order: [[0, 'desc']],
                ajax: {
                    url: '@Url.Action("GetPatternList", "Shift")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;
                        notify.error('Failed to load Shift data');
                    }
                },
                columnDefs: [
                    {
                        targets: -1,
                        className: 'not-export'
                    }
                ],
                 columns: [
                     { data: 'id', title: 'Id', defaultContent: '-', visible: false },
                     { data: 'patternCode', title: 'Pattern Code', defaultContent: '-' },
                     { data: 'patternName', title: 'Pattern Name', defaultContent: '-' },
                     { data: 'cycleLength', title: 'Cycle Length', defaultContent: '-' },                 
                     {
                         data: null,
                         title: 'Action',
                         orderable: false,
                         searchable: false,
                         className: 'text-center action-col',
                         width: '100px',
                         render: function (data, type, row) {
                             return `
                                 <div class="d-flex justify-content-center align-items-center gap-2">
                                     <a href="/Shift/Detail/${row.id}" 
                                        title="Edit">
                                         <i class="fa-solid fa-pen-to-square text-primary"></i>
                                     </a>
                                     <a href="javascript:void(0)"
                                        onclick="confirmDelete(() => deleteRow('${row.id}'))"
                                        title="Delete">
                                         <i class="fa-solid fa-trash text-danger"></i>
                                     </a>
                                 </div>
                             `;
                         }
                     }
                 ] ,
                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    {
                        extend: 'csvHtml5',
                        className: 'btn-export-csv d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    },
                    {
                        extend: 'pdfHtml5',
                        className: 'btn-export-pdf d-none',
                        title: '@Model.Title',
                        exportOptions: {
                            columns: ':not(.not-export)'
                        }
                    }
                ]
            });
            
            $('#csv-export').on('click', function () {
                $('.btn-export-csv').trigger('click');
            });

            $('#pdf-export').on('click', function () {
                $('.btn-export-pdf').trigger('click');
            });

            $('#add-new').on('click', function () {
                showModal();
            });
             $('#save-button').on('click', function () {
                savePattern();
            });
        });

        function savePattern() {
            const form = $('#shiftPatternForm')[0];
            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("AddPattern", "Shift")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Company Shift');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }

        function editRow(id) {
            
        }
        function deleteRow(id) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("DeletePattern", "Shift")',
                data: {
                    id: id
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Company Shift');
                }
            });
        }
        function resetForm() {
            $('#shiftPatternForm')[0].reset();
        }
    </script>
}