@using App.Domain.Enums
@using App.Domain.Models
@using App.Domain.Models.Dto
@using App.Domain.Models.Dto.Masters
@using App.Domain.Models.Dto.Settings
@model PageModel<UserDto>
@{
    ViewData["Title"] = $"Data Master - {Model.Title}";
}

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm full-height-card">
            <div class="card-header py-2 px-3 bg-light">

                <div class="d-flex align-items-center">

                    <h6 class="mb-0 fw-semibold">
                        Existing @Model.Title
                    </h6>

                    <div class="ms-auto d-flex gap-2">
                        <button id="add-new"
                                class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add New
                        </button>

                        <button id="csv-export"
                                class="btn btn-sm btn-outline-success">
                            <i class="fa-solid fa-file-excel me-1"></i>
                            Export CSV
                        </button>

                        <button id="pdf-export"
                                class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-file-pdf me-1"></i>
                            Export PDF
                        </button>

                    </div>

                </div>

            </div>
            <!-- Body -->
            <div class="card-body p-2">
                <div class="table-responsive">
                    <table id="main-table"
                           class="table table-sm table-striped table-hover align-middle w-100 mb-0">
                    </table>
                </div>
            </div>
        </div>
    </div>
     
</div>
 
<div class="modal fade"
     id="UserModal"
     tabindex="-1"
     aria-labelledby="UserModalLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"
                    id="UserModalLabel">
                    <i class="bi bi-stopwatch text-primary me-2"></i>
                    <span id="modalTitle">
                        Add @Model.Title
                    </span>
                </h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>
            <div class="modal-body">
                <form id="UserForm"
                      asp-action="Save"
                      method="post"
                      autocomplete="off">

                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.Mode)
                    @Html.HiddenFor(m => m.Title)
                    @Html.HiddenFor(m => m.Item.PasswordHash)                    
                    @Html.HiddenFor(m => m.Item.Id)

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="row g-3">

                        <!-- Username -->
                        <div class="col-md-4">
                            <label asp-for="Item.Username"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Item.Username"
                                   asp-key="true"
                                   class="form-control"
                                   placeholder="Enter username" />

                            <span asp-validation-for="Item.Username"
                                  class="text-danger small">
                            </span>
                        </div>

                        <!-- Full Name -->
                        <div class="col-md-8">
                            <label asp-for="Item.FullName"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Item.FullName"
                                   class="form-control"
                                   placeholder="Enter full name" />

                            <span asp-validation-for="Item.FullName"
                                  class="text-danger small">
                            </span>
                        </div>

                        <!-- Email -->
                        <div class="col-md-6">
                            <label asp-for="Item.Email"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Item.Email"
                                   type="email"
                                   class="form-control"
                                   placeholder="example@company.com" />

                            <span asp-validation-for="Item.Email"
                                  class="text-danger small">
                            </span>
                        </div>

                        <!-- Status -->
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input asp-for="Item.IsActive"
                                       class="form-check-input"
                                       role="switch" />

                                <label asp-for="Item.IsActive"
                                       class="form-check-label fw-semibold">
                                </label>
                            </div>
                        </div>
 
                        <!-- Password -->
                        <div class="col-md-6">
                            <label asp-for="Item.Password"
                                   class="form-label fw-semibold">
                            </label>

                            <div class="input-group">
                                <input asp-for="Item.Password"
                                       type="password"
                                       class="form-control"
                                       placeholder="Enter password" />

                                <button type="button"
                                        class="btn btn-outline-secondary toggle-password"
                                        data-target="Item_Password">
                                    <i class="fa fa-eye"></i>
                                </button>
                            </div>

                            <span asp-validation-for="Item.Password"
                                  class="text-danger small">
                            </span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="col-md-6">
                            <label asp-for="Item.ConfirmPassword"
                                   class="form-label fw-semibold">
                            </label>

                            <div class="input-group">
                                <input asp-for="Item.ConfirmPassword"
                                       type="password"
                                       class="form-control"
                                       placeholder="Confirm password" />

                                <button type="button"
                                        class="btn btn-outline-secondary toggle-password"
                                        data-target="Item_ConfirmPassword">
                                    <i class="fa fa-eye"></i>
                                </button>
                            </div>

                            <span asp-validation-for="Item.ConfirmPassword"
                                  class="text-danger small">
                            </span>
                        </div>

                      
                        @if (Model.Item.LastLoginDate.HasValue)
                        {
                            <div class="col-md-12">
                                <label class="form-label fw-semibold">
                                    Last Login
                                </label>

                                <input class="form-control"
                                       value="@Model.Item.LastLoginDate.Value.ToString("dd MMM yyyy HH:mm")"
                                       readonly />
                            </div>
                        }

                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-light"
                        type="button"
                        onclick="resetForm()">
                    <i class="bi bi-arrow-clockwise"></i>
                    Reset
                </button>
                <button id="save-button"
                        class="btn btn-primary"
                        type="button">
                    <i class="bi bi-check-circle"></i>
                    Save
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal() {
            const modalElement = document.getElementById('UserModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            setReadonly(false);
            if (modal) {
                modal.hide();
            }
        }
        function showModal(isEdit) {
            $('#modalTitle').text(
                isEdit ? 'Edit User' : 'Add User'
            );

            setReadonly(isEdit);
            const modal = new bootstrap.Modal(
                document.getElementById('UserModal')
            );
            modal.show();
        }
        $(document).ready(function () {
             $('#logoFile').on('change', function () {
                 const file = this.files[0];
                 const preview = document.getElementById('logoPreview');
                 if (!file) {
                     preview.style.display = 'none';
                     return;
                 }
                 preview.src = URL.createObjectURL(file);
                 preview.style.display = 'block';
            });
            const table = $('#main-table').DataTable({
                processing: true,
                serverSide: true,
                responsive: true,
                autoWidth: false,
                filter: true,
                orderMulti: false,
                order: [[0, 'asc']],

                ajax: {
                    url: '@Url.Action("GetList", "User")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify(d);
                    },
                    dataSrc: function (json) {
                        return json.data || [];
                    },
                    error: function (xhr) {
                        if (xhr.status === 401 || xhr.status === 403)
                            return;

                        notify.error("Failed to load overtime types.");
                    }
                },

                columnDefs: [
                    {
                        targets: -1,
                        className: "not-export"
                    }
                ],

                columns: [

                    {
                        data: "username",
                        title: "Username",
                        width: "80px",
                        render: function (data) {
                            return `<span class="fw-bold">${data}</span>`;
                        }
                    },
                    {
                        data: "fullName",
                        title: "Full Name",
                        render: function (data, type, row) {

                            return `
                                <div class="fw-semibold">
                                    ${data}
                                </div>
                                <small class="text-muted">
                                    ${row.description ?? ""}
                                </small>
                            `;
                        }
                    },
                    {
                        data: "isActive",
                        title: "Status",
                        width: "90px",
                        className: "text-center",
                        render: function (data) {

                            return data
                                ? `<span class="badge bg-success">Active</span>`
                                : `<span class="badge bg-danger">Inactive</span>`;
                        }
                    },
                    {
                        data: null,
                        title: "Action",
                        orderable: false,
                        searchable: false,
                        className: "text-center action-col",
                        width: "90px",

                        render: function (data, type, row) {

                            return `

                                <div class="d-flex justify-content-center gap-2">
                                    <a href="javascript:void(0)"
                                       onclick="editRow('${row.username}')"
                                       title="Edit">
                                        <i class="fa-solid fa-pen-to-square text-primary"></i>
                                    </a>
                                    <a href="javascript:void(0)"
                                       onclick="confirmDelete(() => deleteRow('${row.username}'))"
                                       title="Delete">
                                        <i class="fa-solid fa-trash text-danger"></i>
                                    </a>
                                </div>
                            `;
                        }
                    }
                ],
                dom:
                    "B<'row mb-3'<'col-md-6'l><'col-md-6 text-end'f>>" +
                    "rt" +
                    "<'row mt-3'<'col-md-6'i><'col-md-6'p>>",
                buttons: [
                    {
                        extend: "csvHtml5",
                        className: "btn-export-csv d-none",
                        title: "@Model.Title",
                        exportOptions: {
                            columns: ":not(.not-export)"
                        }
                    },
                    {
                        extend: "pdfHtml5",
                        className: "btn-export-pdf d-none",
                        title: "@Model.Title",
                        exportOptions: {
                            columns: ":not(.not-export)"
                        }
                    }
                ]
            });
            
            $('#csv-export').on('click', function () {
                $('.btn-export-csv').trigger('click');
            });

            $('#pdf-export').on('click', function () {
                $('.btn-export-pdf').trigger('click');
            });

            $('#add-new').on('click', function () {
                showModal(false);
            });
             $('#save-button').on('click', function () {
                saveUser();
            });

            $('#Item_IsActive').prop('checked', data.isActive === true);
        });

        function saveUser() {
            const form = $('#UserForm')[0];
            // Trigger client validation
            if (!$('#UserForm').valid()) {
                notify.warning('Please correct the validation errors.');
                return;
            }

            const formData = new FormData(form);
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Add", "User")',
                data: formData,
                processData: false,
                contentType: false,
                beforeSend: function () {
                    $('#save-button').prop('disabled', true);
                },
                success: function (response) {
                    if (response.success) {
                        notify.success(response.message);
                        $('#main-table').DataTable().ajax.reload(null, false);
                        closeModal();
                    }
                    else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('An error occurred while saving Company User');
                },
                complete: function () {
                    $('#save-button').prop('disabled', false);
                }
            });
        }

        function editRow(username) {

            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetData", "User")',
                data: {
                    code: username
                },

                success: function (data) {

                    if (!data) {
                        notify.warning('User information was not found.');
                        return;
                    }

                    // Basic Information
                    $('#Item_Id').val(data.id);
                    $('#Item_Username').val(data.username);
                    $('#Item_FullName').val(data.fullName);
                    $('#Item_Email').val(data.email);

                    // Password fields should always be empty
                    $('#Item_Password').val('');
                    $('#Item_ConfirmPassword').val('');

                    // Status
                    $('#Item_IsActive')
                        .prop('checked', data.isActive);

                    // Optional
                    $('#Item_LastLoginDate')
                        .val(data.lastLoginDate);

                    showModal(true);
                },

                error: function (xhr) {

                    if (xhr.status === 401 ||
                        xhr.status === 403) {
                        return;
                    }

                    notify.error(
                        'Failed to retrieve user information.'
                    );
                }
            });
        }
        function deleteRow(code) {
            $.ajax({
                type: 'DELETE',
                url: '@Url.Action("Delete", "User")',
                data: {
                    code: code
                },
                headers: {
                    'RequestVerificationToken':
                        $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        $('#main-table').DataTable().ajax.reload(null, false);
                        resetForm();
                        notify.success(response.message);
                    } else {
                        notify.warning(response.message);
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 401 || xhr.status === 403)
                        return;
                    notify.error('Failed to delete Company User');
                }
            });
        }
        function resetForm() {
            $('#UserForm')[0].reset();
        }

        $(document).on('click', '.toggle-password', function () {

            const targetId = $(this).data('target');
            const $input = $('#' + targetId);
            const $icon = $(this).find('i');

            if ($input.attr('type') === 'password') {
                $input.attr('type', 'text');
                $icon.removeClass('fa-eye')
                     .addClass('fa-eye-slash');
            }
            else {
                $input.attr('type', 'password');
                $icon.removeClass('fa-eye-slash')
                     .addClass('fa-eye');
            }
        });

        function togglePassword(button) {

            const targetId = $(button).data('target');
            const $input = $('#' + targetId);
            const $icon = $(button).find('i');

            const isPassword = $input.attr('type') === 'password';

            $input.attr('type', isPassword ? 'text' : 'password');

            $icon.toggleClass('fa-eye fa-eye-slash');
        }
    </script>
}
